@page
@model HRM.Razor.Pages.Positions.CreateModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thêm chức vụ mới";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Nhân sự &gt; Chức vụ &gt; <span>Thêm chức vụ</span>
</div>

<div class="page-title-block">
    <h1 class="page-title">Thêm chức vụ mới</h1>
    <p class="page-subtitle">Nhập tên chức vụ và mô tả vị trí công việc cho doanh nghiệp.</p>
</div>

<div class="employee-grid-container">
    <div class="card" style="padding: 2rem;">
        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                </div>
            }

            <div class="form-section-title">
                <i class="bi bi-award"></i> Thông tin chức vụ
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.PositionName" class="form-label"></label>
                <input asp-for="Input.PositionName" class="form-control" placeholder="VD: Trưởng phòng kinh doanh" autofocus />
                <span asp-validation-for="Input.PositionName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Mô tả quyền hạn, trách nhiệm chính của chức vụ..."></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="d-flex align-items-center justify-content-end gap-2" style="margin-top: 2rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
                <a asp-page="/Positions/Index" class="btn btn-outline" style="min-width: 110px;">Hủy</a>
                <button type="submit" class="btn btn-primary" style="min-width: 160px;">
                    <i class="bi bi-check-circle-fill me-1"></i> Tạo chức vụ
                </button>
            </div>
        </form>
    </div>

    <div>
        <div class="side-panel-card">
            <div class="panel-header">
                <i class="bi bi-info-circle"></i>
                <span>Lưu ý bổ sung</span>
            </div>
            <p style="font-size: 0.85rem; color: #64748b; line-height: 1.6; margin: 0;">
                Tên chức vụ phải là duy nhất trong toàn hệ thống. Không cho phép khởi tạo 2 chức vụ trùng tên chỉ vì khác khoảng trắng đầu/cuối.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
