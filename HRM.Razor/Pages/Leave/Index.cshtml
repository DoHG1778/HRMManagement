@page
@model HRM.Razor.Pages.Leave.IndexModel
@{
    ViewData["Title"] = "My Leave Requests";
    Layout = "_Layout";
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title"><i class="bi bi-calendar-event me-2"></i>Yêu cầu nghỉ phép</h5>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Tạo mới
        </a>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <form method="get" class="filter-bar">
            <div class="filter-group">
                <label>Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="PENDING" selected="@(Model.CurrentStatus == "PENDING")">Chờ duyệt</option>
                    <option value="APPROVED" selected="@(Model.CurrentStatus == "APPROVED")">Đã duyệt</option>
                    <option value="REJECTED" selected="@(Model.CurrentStatus == "REJECTED")">Từ chối</option>
                    <option value="CANCELLED" selected="@(Model.CurrentStatus == "CANCELLED")">Đã hủy</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Tháng</label>
                <input type="number" name="month" class="form-control" placeholder="MM" value="@Model.CurrentMonth" min="1" max="12" />
            </div>
            <div class="filter-group">
                <label>Năm</label>
                <input type="number" name="year" class="form-control" placeholder="YYYY" value="@Model.CurrentYear" min="2020" max="2100" />
            </div>
            <button type="submit" class="btn btn-outline">
                <i class="bi bi-funnel me-1"></i> Lọc
            </button>
            <a asp-page="Index" class="btn btn-outline">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Đặt lại
            </a>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Loại phép</th>
                        <th>Từ ngày</th>
                        <th>Đến ngày</th>
                        <th>Số ngày</th>
                        <th>Lý do</th>
                        <th>Trạng thái</th>
                        <th style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LeaveRequests)
                    {
                        <tr>
                            <td>@item.LeaveRequestId</td>
                            <td>@item.LeaveTypeName</td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.TotalDays</td>
                            <td>@item.Reason</td>
                            <td>
                                <span class="badge bg-@(item.Status == "PENDING" ? "warning" : item.Status == "APPROVED" ? "success" : item.Status == "REJECTED" ? "danger" : "secondary")">
                                    @(item.Status == "PENDING" ? "Chờ duyệt" : item.Status == "APPROVED" ? "Đã duyệt" : item.Status == "REJECTED" ? "Từ chối" : "Đã hủy")
                                </span>
                            </td>
                            <td>
                                @if (item.Status == "PENDING")
                                {
                                    <a asp-page="Edit" asp-route-id="@item.LeaveRequestId" class="btn btn-sm btn-outline" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-page-handler="Cancel" method="post" style="display:inline" onsubmit="return confirm('Hủy yêu cầu này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.LeaveRequestId" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Hủy">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.LeaveRequests.Any())
                    {
                        <tr><td colspan="8" class="text-center" style="padding: 2rem; color: var(--color-text-muted);">Không tìm thấy yêu cầu nghỉ phép nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
