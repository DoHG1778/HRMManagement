@page
@model HRM.Razor.Pages.Leave.LeaveTypesModel
@{
    ViewData["Title"] = "Loại phép";
    Layout = "_Layout";
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title"><i class="bi bi-tags me-2"></i>Loại phép</h5>
        <a asp-page="CreateLeaveType" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Tạo mới
        </a>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên loại phép</th>
                        <th>Số ngày/năm</th>
                        <th>Mô tả</th>
                        <th>Trạng thái</th>
                        <th style="width: 160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LeaveTypes)
                    {
                        <tr>
                            <td>@item.LeaveTypeId</td>
                            <td>@item.LeaveTypeName</td>
                            <td>@item.MaxDaysPerYear</td>
                            <td>@item.Description</td>
                            <td>
                                <span class="badge bg-@(item.IsActive ? "success" : "secondary")">@(item.IsActive ? "Đang áp dụng" : "Ngừng áp dụng")</span>
                            </td>
                            <td>
                                <a asp-page="EditLeaveType" asp-route-id="@item.LeaveTypeId" class="btn btn-sm btn-outline" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (item.IsActive)
                                {
                                    <form asp-page-handler="Deactivate" method="post" style="display:inline" onsubmit="return confirm('Ngừng áp dụng loại phép này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.LeaveTypeId" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Ngừng áp dụng">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-page-handler="Activate" method="post" style="display:inline" onsubmit="return confirm('Áp dụng loại phép này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.LeaveTypeId" />
                                        <button type="submit" class="btn btn-sm btn-success" title="Áp dụng">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.LeaveTypes.Any())
                    {
                        <tr><td colspan="6" class="text-center" style="padding: 2rem; color: var(--color-text-muted);">Không tìm thấy loại phép nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
