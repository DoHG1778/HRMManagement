@page
@model HRM.Razor.Pages.Notifications.IndexModel

@{
    ViewData["Title"] = "Thông báo";
    ViewData["ActivePage"] = "Notifications";
}

<div class="page-header mb-4">
    <div>
        <h1>
            <i class="bi bi-bell me-2"></i>
            Thông báo
        </h1>

        <p class="text-muted mb-0">
            Xem các thông báo cá nhân của bạn
        </p>
    </div>
</div>

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">

        <form method="get"
              class="row g-3 align-items-end">

            <div class="col-md-4">

                <label class="form-label">
                    Trạng thái
                </label>

                <select asp-for="IsRead"
                        class="form-select">

                    <option value="">
                        Tất cả
                    </option>

                    <option value="false">
                        Chưa đọc
                    </option>

                    <option value="true">
                        Đã đọc
                    </option>

                </select>

            </div>

            <div class="col-md-4">

                <label class="form-label">
                    Loại thông báo
                </label>

                <input asp-for="NotificationType"
                       class="form-control"
                       placeholder="Ví dụ: KPI, GENERAL..." />

            </div>

            <div class="col-md-auto">

                <button type="submit"
                        class="btn btn-primary">

                    <i class="bi bi-search me-1"></i>

                    Lọc

                </button>

            </div>

        </form>

    </div>
</div>


@if (Model.Notifications.Items == null ||
     !Model.Notifications.Items.Any())
{
    <div class="card">

        <div class="card-body text-center py-5">

            <i class="bi bi-bell-slash"
                   style="font-size: 3rem; color: #94a3b8;">
            </i>

            <h5 class="mt-3">
                Không có thông báo
            </h5>

            <p class="text-muted">
                Hiện tại bạn chưa có thông báo nào.
            </p>

        </div>

    </div>
}
else
{
    <div class="row g-3">

        @foreach (var notification
                    in Model.Notifications.Items)
        {
            <div class="col-12">

                <div class="card
                    @(notification.IsRead
                                             ? ""
                                             : "border-primary")">

                    <div class="card-body">

                        <div class="d-flex
                            justify-content-between
                            align-items-start">

                            <div class="d-flex gap-3">

                                <div>

                                    @if (notification.IsRead)
                                    {
                                        <i class="bi bi-bell text-muted"
                                               style="font-size: 1.5rem;">
                                        </i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-bell-fill text-primary"
                                               style="font-size: 1.5rem;">
                                        </i>
                                    }

                                </div>

                                <div>

                                    <h5 class="mb-1">

                                        @notification.Title

                                        @if (!notification.IsRead)
                                        {
                                            <span class="badge bg-primary ms-2">
                                                Mới
                                            </span>
                                        }

                                    </h5>

                                    <p class="mb-2">
                                        @notification.Content
                                    </p>

                                    <small class="text-muted">

                                        <i class="bi bi-clock me-1"></i>

                                        @notification.CreatedAt
                                        .ToLocalTime()
                                        .ToString("dd/MM/yyyy HH:mm")

                                        @if (!string.IsNullOrWhiteSpace(
                                                                                    notification.NotificationType))
                                        {
                                            <span class="ms-3">

                                                <i class="bi bi-tag me-1"></i>

                                                @notification.NotificationType

                                            </span>
                                        }

                                    </small>

                                </div>

                            </div>

                            <div class="dropdown">

                                <button class="btn btn-light"
                                        type="button"
                                        data-bs-toggle="dropdown">

                                    <i class="bi bi-three-dots-vertical">
                                    </i>

                                </button>

                                <ul class="dropdown-menu dropdown-menu-end">

                                    @if (!notification.IsRead)
                                    {
                                        <li>

                                            <form method="post"
                                                  asp-page-handler="MarkAsRead">

                                                <input type="hidden"
                                                       name="notificationId"
                                                       value="@notification.NotificationId" />

                                                <button type="submit"
                                                        class="dropdown-item">

                                                    <i class="bi bi-check2 me-2">
                                                    </i>

                                                    Đánh dấu đã đọc

                                                </button>

                                            </form>

                                        </li>
                                    }

                                    <li>

                                        <form method="post"
                                              asp-page-handler="Delete">

                                            <input type="hidden"
                                                   name="notificationId"
                                                   value="@notification.NotificationId" />

                                            <button type="submit"
                                                    class="dropdown-item text-danger">

                                                <i class="bi bi-trash me-2">
                                                </i>

                                                Xóa thông báo

                                            </button>

                                        </form>

                                    </li>

                                </ul>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}