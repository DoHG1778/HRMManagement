@page
@model HRM.Razor.Pages.Account.ChangePasswordModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-breadcrumb">
    Hồ sơ cá nhân &gt; <span>Đổi mật khẩu</span>
</div>

<div class="page-title-block">
    <h1 class="page-title">Đổi mật khẩu</h1>
    <p class="page-subtitle">Cập nhật mật khẩu để bảo vệ tài khoản của bạn.</p>
</div>

<div class="change-password-grid">
    <!-- Cột Trái: Form Đổi mật khẩu chính (Khớp Ảnh 2) -->
    <div class="password-form-card">
        <div class="form-card-header">
            <div class="lock-badge-icon" style="background-color: #eff6ff; color: #2563eb;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="password-card-title">Thay đổi mật khẩu</h2>
            <p class="text-muted" style="font-size: 0.875rem;">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới của bạn.</p>
        </div>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                </div>
            }

            <!-- Mật khẩu hiện tại -->
            <div class="form-group mb-3">
                <label asp-for="Input.CurrentPassword" class="form-label"></label>
                <div class="input-icon-group">
                    <i class="bi bi-lock input-icon-left"></i>
                    <input asp-for="Input.CurrentPassword" class="form-control form-control-with-icon" id="CurrentPassword" placeholder="Nhập mật khẩu hiện tại" />
                    <button type="button" class="btn-toggle-password" data-target="CurrentPassword" title="Hiện/Ẩn mật khẩu">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </div>

            <!-- Mật khẩu mới -->
            <div class="form-group mb-3">
                <label asp-for="Input.NewPassword" class="form-label"></label>
                <div class="input-icon-group">
                    <i class="bi bi-lock input-icon-left"></i>
                    <input asp-for="Input.NewPassword" class="form-control form-control-with-icon" id="NewPassword" placeholder="Nhập mật khẩu mới" />
                    <button type="button" class="btn-toggle-password" data-target="NewPassword" title="Hiện/Ẩn mật khẩu">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>

                <!-- Realtime Password Strength Checklist (Khớp Ảnh 2) -->
                <div class="checklist-box">
                    <div class="checklist-title">Mật khẩu mới phải đáp ứng các yêu cầu sau:</div>
                    <div class="checklist-item" id="check-length">
                        <i class="bi bi-circle"></i>
                        <span>Tối thiểu 8 ký tự</span>
                    </div>
                    <div class="checklist-item" id="check-complexity">
                        <i class="bi bi-circle"></i>
                        <span>Bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt</span>
                    </div>
                    <div class="checklist-item" id="check-different">
                        <i class="bi bi-circle"></i>
                        <span>Không trùng với mật khẩu hiện tại</span>
                    </div>
                </div>
            </div>

            <!-- Xác nhận mật khẩu mới -->
            <div class="form-group mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                <div class="input-icon-group">
                    <i class="bi bi-lock input-icon-left"></i>
                    <input asp-for="Input.ConfirmPassword" class="form-control form-control-with-icon" id="ConfirmPassword" placeholder="Nhập lại mật khẩu mới" />
                    <button type="button" class="btn-toggle-password" data-target="ConfirmPassword" title="Hiện/Ẩn mật khẩu">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Option đăng xuất các thiết bị khác -->
            <div class="form-group mb-4" style="background-color: #f8fafc; padding: 0.875rem 1rem; border-radius: 8px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-start gap-2">
                    <input asp-for="Input.SignOutOtherDevices" type="checkbox" id="SignOutOtherDevices" class="form-check-input" style="width: 18px; height: 18px; margin-top: 0.15rem; cursor: pointer;" />
                    <div>
                        <label for="SignOutOtherDevices" class="form-label mb-0" style="font-weight: 600; cursor: pointer;">Đăng xuất khỏi các thiết bị khác</label>
                        <p class="text-muted mb-0" style="font-size: 0.775rem;">Tùy chọn này sẽ đăng xuất tài khoản của bạn trên các thiết bị khác.</p>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions-row">
                <a asp-page="/Index" class="btn btn-outline" style="min-width: 110px;">Hủy</a>
                <button type="submit" class="btn btn-primary" style="min-width: 180px;">Cập nhật mật khẩu</button>
            </div>
        </form>
    </div>

    <!-- Cột Phải: Side Panels Mẹo bảo mật & Thông tin bảo mật (Khớp Ảnh 2) -->
    <div class="side-panels-column">
        <!-- Panel 1: Mẹo bảo mật -->
        <div class="side-panel-card">
            <div class="panel-header">
                <i class="bi bi-shield-check"></i>
                <span>Mẹo bảo mật</span>
            </div>

            <div class="tip-item">
                <div class="tip-icon-badge">
                    <i class="bi bi-lock"></i>
                </div>
                <div class="tip-content">
                    <h5>Sử dụng mật khẩu mạnh, khó đoán</h5>
                    <p>Kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
                </div>
            </div>

            <div class="tip-item">
                <div class="tip-icon-badge">
                    <i class="bi bi-person-bounding-box"></i>
                </div>
                <div class="tip-content">
                    <h5>Không chia sẻ mật khẩu</h5>
                    <p>Không chia sẻ mật khẩu với bất kỳ ai, kể cả đồng nghiệp.</p>
                </div>
            </div>

            <div class="tip-item">
                <div class="tip-icon-badge">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="tip-content">
                    <h5>Thay đổi mật khẩu định kỳ</h5>
                    <p>Nên thay đổi mật khẩu sau mỗi 3-6 tháng.</p>
                </div>
            </div>

            <div class="tip-item">
                <div class="tip-icon-badge">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div class="tip-content">
                    <h5>Bật xác thực 2 bước</h5>
                    <p>Tăng cường bảo mật cho tài khoản của bạn.</p>
                </div>
            </div>

            <div class="last-updated-box">
                <i class="bi bi-calendar-event text-primary" style="font-size: 1.2rem;"></i>
                <div>
                    <div style="font-size: 0.75rem; color: #64748b;">Mật khẩu đã được cập nhật lần cuối:</div>
                    <strong>15/06/2025</strong>
                </div>
            </div>
        </div>

        <!-- Panel 2: Thông tin bảo mật tài khoản -->
        <div class="side-panel-card">
            <div class="panel-header" style="margin-bottom: 0.75rem;">
                <span>Thông tin bảo mật tài khoản</span>
            </div>

            <div class="info-status-list">
                <div class="info-status-item">
                    <div class="info-left">
                        <i class="bi bi-laptop"></i>
                        <div class="info-text">
                            <h6>Đăng nhập gần đây</h6>
                            <p>Hôm nay, 09:15</p>
                        </div>
                    </div>
                    <i class="bi bi-chevron-right text-muted"></i>
                </div>

                <div class="info-status-item">
                    <div class="info-left">
                        <i class="bi bi-display"></i>
                        <div class="info-text">
                            <h6>Thiết bị hiện tại</h6>
                            <p>Windows &middot; Chrome 125.0</p>
                        </div>
                    </div>
                    <i class="bi bi-chevron-right text-muted"></i>
                </div>

                <div class="info-status-item">
                    <div class="info-left">
                        <i class="bi bi-shield-check"></i>
                        <div class="info-text">
                            <h6>Xác thực 2 bước</h6>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge badge-warning" style="font-size: 0.7rem;">Chưa bật</span>
                        <i class="bi bi-chevron-right text-muted"></i>
                    </div>
                </div>

                <div class="info-status-item">
                    <div class="info-left">
                        <i class="bi bi-clock"></i>
                        <div class="info-text">
                            <h6>Lịch sử hoạt động</h6>
                            <p>Xem các hoạt động gần đây</p>
                        </div>
                    </div>
                    <i class="bi bi-chevron-right text-muted"></i>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
