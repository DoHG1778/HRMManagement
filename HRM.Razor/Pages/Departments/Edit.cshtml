@page "{id:int}"
@model HRM.Razor.Pages.Departments.EditModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Chỉnh sửa - {Model.Input.DepartmentName}";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Nhân sự &gt; Phòng ban &gt; <span>Chỉnh sửa phòng ban</span>
</div>

<div class="page-title-block">
    <h1 class="page-title">Chỉnh sửa phòng ban</h1>
    <p class="page-subtitle">Cập nhật tên, mô tả và quản lý chỉ định của phòng ban @Model.Input.DepartmentName.</p>
</div>

<div class="employee-grid-container">
    <div class="card" style="padding: 2rem;">
        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Input.DepartmentId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                </div>
            }

            <div class="form-section-title">
                <i class="bi bi-pencil-square"></i> Thông tin phòng ban
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.DepartmentName" class="form-label"></label>
                <input asp-for="Input.DepartmentName" class="form-control" placeholder="VD: Phòng Công nghệ thông tin" />
                <span asp-validation-for="Input.DepartmentName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.ManagerEmployeeId" class="form-label"></label>
                <select asp-for="Input.ManagerEmployeeId" asp-items="Model.ManagerOptions" class="form-control"></select>
                <span asp-validation-for="Input.ManagerEmployeeId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Mô tả chức năng, nhiệm vụ của phòng ban..."></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" id="IsActiveCheck" />
                    <label class="form-check-label" for="IsActiveCheck">
                        Phòng ban đang trong trạng thái hoạt động
                    </label>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-end gap-2" style="margin-top: 2rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
                <a asp-page="/Departments/Index" class="btn btn-outline" style="min-width: 110px;">Hủy</a>
                <button type="submit" class="btn btn-primary" style="min-width: 160px;">
                    <i class="bi bi-floppy-fill me-1"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>

    <div>
        <div class="side-panel-card">
            <div class="panel-header">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Lưu ý khi ngừng hoạt động</span>
            </div>
            <p style="font-size: 0.85rem; color: #64748b; line-height: 1.6; margin: 0;">
                Nếu tắt trạng thái hoạt động (Deactivate), phòng ban phải <strong>không còn nhân viên nào đang active</strong>. Nếu vẫn còn nhân viên, hệ thống sẽ từ chối và yêu cầu điều chuyển nhân viên trước.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
