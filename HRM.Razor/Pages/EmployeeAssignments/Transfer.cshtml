@page "{employeeId:int}"
@model HRM.Razor.Pages.EmployeeAssignments.TransferModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Điều chuyển nhân viên - {Model.Employee.FullName}";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/employee-assignment.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Nhân sự &gt; Phân công nhân viên &gt; <span>Điều chuyển nhân viên</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Điều chuyển nhân viên</h1>
        <p class="page-subtitle mb-0">Chuyển nhân viên sang phòng ban hoặc chức vụ khác</p>
    </div>

    <a asp-page="/Employees/Details" asp-route-id="@Model.Employee.EmployeeId" class="btn btn-outline">
        <i class="bi bi-arrow-left me-1"></i> Quay lại chi tiết nhân viên
    </a>
</div>

<div class="assignment-container">
    <!-- Left Column: Form Transfer -->
    <div>
        <!-- Card 1: Readonly Current Employee & Assignment Info -->
        <div class="card mb-4" style="padding: 1.5rem;">
            <div class="form-section-title mb-3">
                <i class="bi bi-person-vcard"></i> Thông tin nhân viên
            </div>

            <div class="d-flex align-items-center gap-3 mb-3 border-bottom pb-3">
                <div style="width: 52px; height: 52px; border-radius: 50%; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem;">
                    @(Model.Employee.FullName != null && Model.Employee.FullName.Length > 0 ? Model.Employee.FullName.Substring(0, 1).ToUpper() : "E")
                </div>
                <div style="flex: 1;">
                    <div class="d-flex align-items-center gap-2">
                        <strong style="font-size: 1.1rem; color: #0f172a;">@Model.Employee.EmployeeCode - @Model.Employee.FullName</strong>
                        <span class="badge-status badge-status-active">@Model.Employee.EmploymentStatus</span>
                    </div>
                    <div class="text-muted" style="font-size: 0.85rem;">Email: @Model.Employee.Email</div>
                </div>
            </div>

            @if (Model.HasCurrentAssignment && Model.CurrentAssignment != null)
            {
                <div class="row g-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.88rem;">
                    <div>
                        <span class="text-muted">Phòng ban hiện tại:</span>
                        <div style="font-weight: 700; color: #0f172a;" id="currentDeptName">@Model.CurrentAssignment.DepartmentName</div>
                    </div>
                    <div>
                        <span class="text-muted">Chức vụ hiện tại:</span>
                        <div style="font-weight: 700; color: #0f172a;" id="currentPosName">@Model.CurrentAssignment.PositionName</div>
                    </div>
                    <div>
                        <span class="text-muted">Quản lý trực tiếp:</span>
                        <div>@(Model.Employee.ManagerName ?? "Chưa bổ nhiệm")</div>
                    </div>
                    <div>
                        <span class="text-muted">Ngày phân công hiện tại:</span>
                        <div>@Model.CurrentAssignment.StartDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Nhân viên chưa có phân công hiện tại. Vui lòng gán phân công đầu tiên trước khi thực hiện điều chuyển.
                    <div class="mt-2">
                        <a asp-page="/EmployeeAssignments/Assign" asp-route-employeeId="@Model.Employee.EmployeeId" class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Đến trang Gán nhân viên
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Card 2: Transfer Inputs -->
        @if (Model.HasCurrentAssignment)
        {
            <div class="card" style="padding: 1.75rem;">
                <form method="post" id="transferForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                        </div>
                    }

                    <div class="form-section-title mb-3">
                        <i class="bi bi-arrow-left-right"></i> Thông tin điều chuyển
                    </div>

                    <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div>
                            <label asp-for="Input.DepartmentId" class="form-label required-label"></label>
                            <select asp-for="Input.DepartmentId" asp-items="Model.DepartmentOptions" class="form-control" id="newDeptSelect"></select>
                            <span asp-validation-for="Input.DepartmentId" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="Input.PositionId" class="form-label required-label"></label>
                            <select asp-for="Input.PositionId" asp-items="Model.PositionOptions" class="form-control" id="newPosSelect"></select>
                            <span asp-validation-for="Input.PositionId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div>
                            <label asp-for="Input.StartDate" class="form-label required-label"></label>
                            <input asp-for="Input.StartDate" type="date" class="form-control" id="newStartDateInput" onchange="updateCalculatedEndDate()" />
                            <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                        </div>

                        <div>
                            <label class="form-label text-muted">Ngày kết thúc (phân công cũ)</label>
                            <input type="text" id="calculatedOldEndDate" class="form-control" readonly style="background-color: #f1f5f9; color: #64748b;" />
                            <small class="text-muted">Tự động bằng ngày trước ngày bắt đầu mới</small>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Note" class="form-label required-label"></label>
                        <textarea asp-for="Input.Note" class="form-control" rows="3" placeholder="Nhập lý do điều chuyển nhân viên (VD: Điều chuyển sang dự án mới)..." id="transferNoteInput"></textarea>
                        <span asp-validation-for="Input.Note" class="text-danger"></span>
                    </div>

                    <div class="d-flex align-items-center justify-content-end gap-2" style="margin-top: 1.5rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
                        <a asp-page="/Employees/Details" asp-route-id="@Model.Employee.EmployeeId" class="btn btn-outline" style="min-width: 100px;">Hủy</a>
                        <button type="button" class="btn btn-primary" style="min-width: 170px;" onclick="openTransferModal()">
                            <i class="bi bi-arrow-left-right me-1"></i> Điều chuyển nhân viên
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>

    <!-- Right Column: Assignment History Timeline (Matching Mockup 2) -->
    <div>
        <div class="card" style="padding: 1.5rem;">
            <div class="form-section-title mb-3">
                <i class="bi bi-clock-history"></i> Lịch sử phân công
            </div>

            @if (Model.AssignmentHistory != null && Model.AssignmentHistory.Any())
            {
                <div class="assignment-timeline">
                    @foreach (var item in Model.AssignmentHistory)
                    {
                        var isCurrent = item.IsCurrent;
                        <div class="timeline-item @(isCurrent ? "current" : "")">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <span style="font-size: 0.8rem; font-weight: 700; color: #64748b;">
                                        @item.StartDate.ToString("dd/MM/yyyy") - @(item.EndDate.HasValue ? item.EndDate.Value.ToString("dd/MM/yyyy") : "Hiện tại")
                                    </span>
                                    @if (isCurrent)
                                    {
                                        <span class="badge" style="background-color: #dcfce7; color: #166534; font-size: 0.7rem; padding: 0.2rem 0.5rem;">Hiện tại</span>
                                    }
                                </div>
                                <div style="font-weight: 700; color: #0f172a;">@item.DepartmentName</div>
                                <div style="font-size: 0.85rem; color: #334155;">@item.PositionName</div>
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    <div class="text-muted mt-1" style="font-size: 0.78rem; font-style: italic;">
                                        <i class="bi bi-chat-left-text me-1"></i>@item.Note
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted text-center py-4" style="font-size: 0.85rem;">
                    <i class="bi bi-inbox" style="font-size: 1.8rem; color: #cbd5e1; display: block; margin-bottom: 0.5rem;"></i>
                    Chưa có lịch sử phân công.
                </div>
            }
        </div>

        <div class="alert alert-info mt-3" style="font-size: 0.85rem; border-radius: 12px;">
            <i class="bi bi-info-circle-fill me-1"></i>
            <strong>Lưu ý:</strong>
            <ul class="mb-0 ps-3 mt-1" style="line-height: 1.5;">
                <li>Hệ thống tự động kết thúc phân công hiện tại vào ngày trước ngày bắt đầu phân công mới.</li>
                <li>Toàn bộ lịch sử phân công cũ được bảo lưu 100%.</li>
            </ul>
        </div>
    </div>
</div>

<partial name="Partials/_TransferConfirmModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateCalculatedEndDate() {
            var startDateVal = document.getElementById('newStartDateInput').value;
            if (startDateVal) {
                var dt = new Date(startDateVal);
                dt.setDate(dt.getDate() - 1);
                var day = String(dt.getDate()).padStart(2, '0');
                var month = String(dt.getMonth() + 1).padStart(2, '0');
                var year = dt.getFullYear();
                document.getElementById('calculatedOldEndDate').value = day + '/' + month + '/' + year;
            } else {
                document.getElementById('calculatedOldEndDate').value = '-';
            }
        }

        function openTransferModal() {
            var empName = "@Model.Employee.FullName";
            var oldDept = document.getElementById('currentDeptName') ? document.getElementById('currentDeptName').innerText : '-';
            var oldPos = document.getElementById('currentPosName') ? document.getElementById('currentPosName').innerText : '-';
            
            var newDeptSelect = document.getElementById('newDeptSelect');
            var newPosSelect = document.getElementById('newPosSelect');
            var newDeptText = newDeptSelect.options[newDeptSelect.selectedIndex] ? newDeptSelect.options[newDeptSelect.selectedIndex].text : '-';
            var newPosText = newPosSelect.options[newPosSelect.selectedIndex] ? newPosSelect.options[newPosSelect.selectedIndex].text : '-';
            
            var startDate = document.getElementById('newStartDateInput').value;
            var note = document.getElementById('transferNoteInput').value;

            document.getElementById('modalEmployeeName').innerText = empName;
            document.getElementById('modalOldDept').innerText = oldDept;
            document.getElementById('modalNewDept').innerText = newDeptText;
            document.getElementById('modalOldPos').innerText = oldPos;
            document.getElementById('modalNewPos').innerText = newPosText;
            document.getElementById('modalStartDate').innerText = startDate ? startDate : '-';
            document.getElementById('modalNote').innerText = note ? note : '(Không có ghi chú)';

            var modal = new bootstrap.Modal(document.getElementById('transferConfirmModal'));
            modal.show();
        }

        document.getElementById('confirmTransferSubmitBtn').addEventListener('click', function() {
            document.getElementById('transferForm').submit();
        });

        document.addEventListener("DOMContentLoaded", function() {
            updateCalculatedEndDate();
        });
    </script>
}
