@page "{id:int}"
@model HRM.Razor.Pages.AttendanceAdjustments.DetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết yêu cầu điều chỉnh";

    var statusBadgeClass = Model.Adjustment.Status switch
    {
        "APPROVED" => "badge-approved",
        "REJECTED" => "badge-rejected",
        "CANCELLED" => "badge-cancelled",
        _ => "badge-pending"
    };

    var statusText = Model.Adjustment.Status switch
    {
        "APPROVED" => "Đã duyệt",
        "REJECTED" => "Từ chối",
        "CANCELLED" => "Đã hủy",
        _ => "Chờ duyệt"
    };
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-adjustment.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Chấm công &gt; Điều chỉnh chấm công &gt; <span>Chi tiết yêu cầu</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Chi tiết yêu cầu điều chỉnh chấm công</h1>
        <p class="page-subtitle mb-0">Xem thông tin chi tiết và lịch sử phê duyệt yêu cầu</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="/AttendanceAdjustments/Index" class="btn btn-outline">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        @if (Model.Adjustment.Status == "PENDING")
        {
            <a asp-page="/AttendanceAdjustments/Edit" asp-route-id="@Model.Adjustment.AdjustmentId" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i> Chỉnh sửa
            </a>
        }
    </div>
</div>

<!-- Header Info Card -->
<div class="card mb-4" style="padding: 1.5rem;">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <h3 class="mb-0" style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">
                    Yêu cầu điều chỉnh ngày @Model.Adjustment.AttendanceDate.ToString("dd/MM/yyyy")
                </h3>
                <span class="@statusBadgeClass">@statusText</span>
            </div>
            <div class="text-muted" style="font-size: 0.88rem;">
                Người đề xuất: <strong>@(Model.Adjustment.RequestedByName ?? Model.Adjustment.EmployeeCode ?? "Nhân viên")</strong> | Ngày gửi: <strong>@Model.Adjustment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
        </div>
    </div>
</div>

<!-- 2-Column Comparison Box -->
<div class="comparison-box mb-4">
    <!-- Col 1: Original -->
    <div class="comparison-col-original">
        <h5 class="mb-3 border-bottom pb-2" style="font-size: 1rem; font-weight: 700; color: #334155;">
            Thông tin chấm công gốc
        </h5>

        <div class="mb-3">
            <label class="form-label text-muted">Ngày chấm công</label>
            <div style="font-size: 1.05rem; font-weight: 700; color: #0f172a;">
                @Model.Adjustment.AttendanceDate.ToString("dd/MM/yyyy")
            </div>
        </div>

        <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr;">
            <div>
                <label class="form-label text-muted">Giờ vào (gốc)</label>
                <div style="font-size: 1rem; font-weight: 600; color: #475569;">
                    @(Model.Adjustment.OriginalCheckInTime.HasValue ? Model.Adjustment.OriginalCheckInTime.Value.ToString("HH:mm") : "--:--")
                </div>
            </div>

            <div>
                <label class="form-label text-muted">Giờ ra (gốc)</label>
                <div style="font-size: 1rem; font-weight: 600; color: #475569;">
                    @(Model.Adjustment.OriginalCheckOutTime.HasValue ? Model.Adjustment.OriginalCheckOutTime.Value.ToString("HH:mm") : "--:--")
                </div>
            </div>
        </div>

        <div>
            <label class="form-label text-muted">Tổng giờ làm (gốc)</label>
            <div style="font-size: 1.1rem; font-weight: 700; color: #334155;">
                @(Model.Adjustment.OriginalWorkingHours.HasValue ? $"{Model.Adjustment.OriginalWorkingHours} giờ" : "0 giờ")
            </div>
        </div>
    </div>

    <!-- Col 2: Proposed -->
    <div class="comparison-col-proposed">
        <h5 class="mb-3 border-bottom pb-2" style="font-size: 1rem; font-weight: 700; color: #1e40af;">
            Thông tin đề xuất
        </h5>

        <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr;">
            <div>
                <label class="form-label text-muted">Giờ vào (đề xuất)</label>
                <div style="font-size: 1.05rem; font-weight: 700; color: #2563eb;">
                    @(Model.Adjustment.RequestedCheckInTime.HasValue ? Model.Adjustment.RequestedCheckInTime.Value.ToString("HH:mm dd/MM/yyyy") : "--:--")
                </div>
            </div>

            <div>
                <label class="form-label text-muted">Giờ ra (đề xuất)</label>
                <div style="font-size: 1.05rem; font-weight: 700; color: #2563eb;">
                    @(Model.Adjustment.RequestedCheckOutTime.HasValue ? Model.Adjustment.RequestedCheckOutTime.Value.ToString("HH:mm dd/MM/yyyy") : "--:--")
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label text-muted">Lý do điều chỉnh</label>
            <div style="font-size: 0.95rem; color: #0f172a; background-color: #ffffff; padding: 0.75rem; border-radius: 8px; border: 1px solid #bfdbfe;">
                @Model.Adjustment.Reason
            </div>
        </div>
    </div>
</div>

<!-- Approval History Info -->
@if (Model.Adjustment.Status == "APPROVED" || Model.Adjustment.Status == "REJECTED")
{
    <div class="card" style="padding: 1.5rem;">
        <h5 class="mb-3 border-bottom pb-2" style="font-size: 1rem; font-weight: 700; color: #0f172a;">
            Kết quả phê duyệt
        </h5>

        <div class="d-flex flex-column gap-2" style="font-size: 0.9rem;">
            <div>Người phê duyệt: <strong>@(Model.Adjustment.ApprovedByName ?? "Quản lý phòng ban")</strong></div>
            <div>Thời điểm xử lý: <strong>@(Model.Adjustment.ApprovedAt.HasValue ? Model.Adjustment.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm") : "--/--/----")</strong></div>
            
            @if (Model.Adjustment.Status == "REJECTED" && !string.IsNullOrWhiteSpace(Model.Adjustment.RejectionReason))
            {
                <div class="mt-2 p-3" style="background-color: #fef2f2; border-radius: 10px; border: 1px solid #fecaca;">
                    <label class="form-label text-danger font-weight-bold mb-1">Lý do từ chối:</label>
                    <div style="color: #991b1b;">@Model.Adjustment.RejectionReason</div>
                </div>
            }
        </div>
    </div>
}
