@page
@model HRM.Razor.Pages.AttendanceAdjustments.ApprovalsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Phê duyệt điều chỉnh chấm công";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-adjustment.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Chấm công &gt; <span>Phê duyệt điều chỉnh</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Phê duyệt điều chỉnh chấm công</h1>
        <p class="page-subtitle mb-0">Xem và xử lý các yêu cầu điều chỉnh chấm công của nhân viên trong phòng ban</p>
    </div>
</div>

<!-- Department Summary Metric Cards (Matching Mockup UC20) -->
<div class="row g-3 mb-4" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 48px; height: 48px; border-radius: 12px; background-color: #fef3c7; color: #d97706; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
            <i class="bi bi-clock-history"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.8rem; font-weight: 600;">Chờ duyệt</div>
            <div style="font-size: 1.3rem; font-weight: 700; color: #d97706;">@Model.PendingCount</div>
        </div>
    </div>
</div>

<!-- Filter Bar -->
<div class="card mb-4" style="padding: 1.25rem;">
    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
        <div style="width: 130px;">
            <select asp-for="Month" class="form-control">
                <option value="">Tất cả tháng</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">Tháng @m</option>
                }
            </select>
        </div>

        <div style="width: 130px;">
            <select asp-for="Year" class="form-control">
                @for (int y = 2024; y <= 2026; y++)
                {
                    <option value="@y">Năm @y</option>
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary" style="height: 42px;">
            <i class="bi bi-funnel me-1"></i> Lọc
        </button>
        <a asp-page="/AttendanceAdjustments/Approvals" class="btn btn-outline" style="height: 42px;">Đặt lại</a>
    </form>
</div>

<!-- Table Pending Adjustments (Matching Mockup UC20) -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
            <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                <tr>
                    <th style="padding: 0.85rem 1rem; width: 40px;">STT</th>
                    <th style="padding: 0.85rem 1rem;">Nhân viên</th>
                    <th style="padding: 0.85rem 1rem;">Ngày chấm công</th>
                    <th style="padding: 0.85rem 1rem;">Giờ gốc (vào - ra)</th>
                    <th style="padding: 0.85rem 1rem;">Giờ đề xuất (vào - ra)</th>
                    <th style="padding: 0.85rem 1rem;">Lý do</th>
                    <th style="padding: 0.85rem 1rem;">Ngày gửi</th>
                    <th style="padding: 0.85rem 1rem; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PendingRequests != null && Model.PendingRequests.Any())
                {
                    int index = 1;
                    foreach (var item in Model.PendingRequests)
                    {
                        var origIn = item.OriginalCheckInTime.HasValue ? item.OriginalCheckInTime.Value.ToString("HH:mm") : "--:--";
                        var origOut = item.OriginalCheckOutTime.HasValue ? item.OriginalCheckOutTime.Value.ToString("HH:mm") : "--:--";
                        var reqIn = item.RequestedCheckInTime.HasValue ? item.RequestedCheckInTime.Value.ToString("HH:mm") : "--:--";
                        var reqOut = item.RequestedCheckOutTime.HasValue ? item.RequestedCheckOutTime.Value.ToString("HH:mm") : "--:--";

                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 0.85rem 1rem; color: #64748b;">@index</td>
                            <td style="padding: 0.85rem 1rem; font-weight: 700; color: #0f172a;">
                                @(item.EmployeeCode ?? "") - @(item.RequestedByName ?? "Nhân viên")
                                <div class="text-muted" style="font-size: 0.78rem; font-weight: 400;">@(item.PositionName ?? item.DepartmentName ?? "")</div>
                            </td>
                            <td style="padding: 0.85rem 1rem; font-weight: 600; color: #334155;">
                                @item.AttendanceDate.ToString("dd/MM/yyyy")
                            </td>
                            <td style="padding: 0.85rem 1rem; color: #64748b;">
                                @origIn - @origOut
                            </td>
                            <td style="padding: 0.85rem 1rem; font-weight: 700; color: #2563eb;">
                                @reqIn - @reqOut
                            </td>
                            <td style="padding: 0.85rem 1rem; max-width: 200px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                                @item.Reason
                            </td>
                            <td style="padding: 0.85rem 1rem; color: #64748b; font-size: 0.8rem;">
                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td style="padding: 0.85rem 1rem; text-align: center;">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                    <a asp-page="/AttendanceAdjustments/Details" asp-route-id="@item.AdjustmentId" class="btn btn-outline" style="padding: 0.25rem 0.45rem; font-size: 0.8rem;" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-success" style="padding: 0.25rem 0.55rem; font-size: 0.8rem;" title="Duyệt" onclick="openApproveModal(@item.AdjustmentId, '@item.RequestedByName', '@item.AttendanceDate.ToString("dd/MM/yyyy")')">
                                        <i class="bi bi-check-lg"></i> Duyệt
                                    </button>
                                    <button type="button" class="btn btn-danger" style="padding: 0.25rem 0.55rem; font-size: 0.8rem;" title="Từ chối" onclick="openRejectModal(@item.AdjustmentId, '@item.RequestedByName', '@item.AttendanceDate.ToString("dd/MM/yyyy")')">
                                        <i class="bi bi-x-lg"></i> Từ chối
                                    </button>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted" style="padding: 3rem 1rem;">
                            <i class="bi bi-check-circle" style="font-size: 2rem; color: #cbd5e1; display: block; margin-bottom: 0.5rem;"></i>
                            Không có yêu cầu điều chỉnh chấm công nào đang chờ duyệt.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Phê duyệt (Approve Modal UC20) -->
<div class="modal fade" id="approveAdjustmentModal" tabindex="-1" aria-labelledby="approveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
            <div class="modal-header" style="background-color: #f0fdf4; border-bottom: 1px solid #bbf7d0; padding: 1.25rem 1.5rem;">
                <h5 class="modal-header-title d-flex align-items-center gap-2" id="approveModalLabel" style="font-size: 1.1rem; font-weight: 700; color: #166534; margin: 0;">
                    <i class="bi bi-check-circle-fill"></i> Phê duyệt yêu cầu điều chỉnh chấm công
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <p>Xác nhận phê duyệt yêu cầu điều chỉnh cho nhân viên <strong id="approveEmpName">--</strong> ngày <strong id="approveDateText">--/--/----</strong>?</p>
                <div class="alert alert-success" style="font-size: 0.85rem; margin: 0;">
                    <i class="bi bi-info-circle me-1"></i> Sau khi phê duyệt, thời gian vào/ra và tổng số giờ làm trên bảng chấm công gốc của nhân viên sẽ tự động được cập nhật.
                </div>
                <form method="post" asp-page-handler="Approve" id="approveForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="approveAdjustmentId" />
                </form>
            </div>
            <div class="modal-footer" style="background-color: #f8fafc; border-top: 1px solid #e2e8f0; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success" onclick="document.getElementById('approveForm').submit();">
                    <i class="bi bi-check-circle me-1"></i> Xác nhận phê duyệt
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Từ chối (Reject Modal UC20) -->
<div class="modal fade" id="rejectAdjustmentModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
            <div class="modal-header" style="background-color: #fef2f2; border-bottom: 1px solid #fecaca; padding: 1.25rem 1.5rem;">
                <h5 class="modal-header-title d-flex align-items-center gap-2" id="rejectModalLabel" style="font-size: 1.1rem; font-weight: 700; color: #991b1b; margin: 0;">
                    <i class="bi bi-x-circle-fill"></i> Từ chối yêu cầu điều chỉnh
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <p>Từ chối yêu cầu của nhân viên <strong id="rejectEmpName">--</strong> ngày <strong id="rejectDateText">--/--/----</strong>?</p>
                <form method="post" asp-page-handler="Reject" id="rejectForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="rejectAdjustmentId" />
                    
                    <div class="form-group mb-3">
                        <label for="rejectionReasonInput" class="form-label required-label">Lý do từ chối</label>
                        <textarea name="rejectionReason" id="rejectionReasonInput" class="form-control" rows="3" placeholder="Nhập lý do từ chối yêu cầu này..." required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="background-color: #f8fafc; border-top: 1px solid #e2e8f0; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" onclick="submitRejectForm()">
                    <i class="bi bi-x-circle me-1"></i> Xác nhận từ chối
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openApproveModal(id, empName, dateStr) {
            document.getElementById('approveAdjustmentId').value = id;
            document.getElementById('approveEmpName').innerText = empName;
            document.getElementById('approveDateText').innerText = dateStr;
            var modal = new bootstrap.Modal(document.getElementById('approveAdjustmentModal'));
            modal.show();
        }

        function openRejectModal(id, empName, dateStr) {
            document.getElementById('rejectAdjustmentId').value = id;
            document.getElementById('rejectEmpName').innerText = empName;
            document.getElementById('rejectDateText').innerText = dateStr;
            document.getElementById('rejectionReasonInput').value = '';
            var modal = new bootstrap.Modal(document.getElementById('rejectAdjustmentModal'));
            modal.show();
        }

        function submitRejectForm() {
            var reason = document.getElementById('rejectionReasonInput').value.trim();
            if (!reason) {
                alert('Vui lòng nhập lý do từ chối.');
                return;
            }
            document.getElementById('rejectForm').submit();
        }
    </script>
}
