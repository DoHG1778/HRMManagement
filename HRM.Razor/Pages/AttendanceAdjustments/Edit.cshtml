@page "{id:int}"
@model HRM.Razor.Pages.AttendanceAdjustments.EditModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chỉnh sửa yêu cầu điều chỉnh";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/attendance-adjustment.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Chấm công &gt; Điều chỉnh chấm công &gt; <span>Chỉnh sửa yêu cầu</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Chỉnh sửa yêu cầu điều chỉnh chấm công</h1>
        <p class="page-subtitle mb-0">Cập nhật lại thời gian vào/ra đề xuất hoặc lý do điều chỉnh</p>
    </div>

    <a asp-page="/AttendanceAdjustments/Index" class="btn btn-outline">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Input.AdjustmentId" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mb-4" role="alert">
            <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
        </div>
    }

    <!-- 2-Column Side-by-Side Comparison Box (Matching Mockup UC19) -->
    <div class="comparison-box mb-4">
        <!-- Col 1: Original Attendance Info -->
        <div class="comparison-col-original">
            <h5 class="mb-3 border-bottom pb-2" style="font-size: 1rem; font-weight: 700; color: #334155;">
                <i class="bi bi-calendar-event me-1"></i> Thông tin chấm công gốc
            </h5>

            <div class="mb-3">
                <label class="form-label text-muted">Ngày chấm công</label>
                <div style="font-size: 1.1rem; font-weight: 700; color: #0f172a;">
                    @Model.Adjustment.AttendanceDate.ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label class="form-label text-muted">Giờ vào (gốc)</label>
                    <div style="font-size: 1rem; font-weight: 600; color: #475569;">
                        @(Model.Adjustment.OriginalCheckInTime.HasValue ? Model.Adjustment.OriginalCheckInTime.Value.ToString("HH:mm") : "--:--")
                    </div>
                </div>

                <div>
                    <label class="form-label text-muted">Giờ ra (gốc)</label>
                    <div style="font-size: 1rem; font-weight: 600; color: #475569;">
                        @(Model.Adjustment.OriginalCheckOutTime.HasValue ? Model.Adjustment.OriginalCheckOutTime.Value.ToString("HH:mm") : "--:--")
                    </div>
                </div>
            </div>

            <div>
                <label class="form-label text-muted">Tổng giờ làm (gốc)</label>
                <div style="font-size: 1.1rem; font-weight: 700; color: #334155;">
                    @(Model.Adjustment.OriginalWorkingHours.HasValue ? $"{Model.Adjustment.OriginalWorkingHours} giờ" : "0 giờ")
                </div>
            </div>
        </div>

        <!-- Col 2: Proposed Time Inputs -->
        <div class="comparison-col-proposed">
            <h5 class="mb-3 border-bottom pb-2" style="font-size: 1rem; font-weight: 700; color: #1e40af;">
                <i class="bi bi-pencil-square me-1"></i> Thông tin đề xuất
            </h5>

            <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label asp-for="Input.RequestedCheckInTime" class="form-label required-label"></label>
                    <input asp-for="Input.RequestedCheckInTime" type="datetime-local" class="form-control" id="reqCheckInInput" onchange="calcProposedWorkingHours()" />
                    <span asp-validation-for="Input.RequestedCheckInTime" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Input.RequestedCheckOutTime" class="form-label required-label"></label>
                    <input asp-for="Input.RequestedCheckOutTime" type="datetime-local" class="form-control" id="reqCheckOutInput" onchange="calcProposedWorkingHours()" />
                    <span asp-validation-for="Input.RequestedCheckOutTime" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Reason" class="form-label required-label"></label>
                <textarea asp-for="Input.Reason" class="form-control" rows="3" placeholder="VD: Quên chấm công lúc 08:00..."></textarea>
                <span asp-validation-for="Input.Reason" class="text-danger"></span>
            </div>

            <div class="p-3" style="background-color: #ffffff; border-radius: 10px; border: 1px solid #bfdbfe;">
                <label class="form-label text-muted mb-1">Tổng giờ làm (dự kiến)</label>
                <div style="font-size: 1.25rem; font-weight: 800; color: #2563eb;" id="proposedHoursDisplay">-- giờ</div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex align-items-center justify-content-end gap-2" style="border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
        <a asp-page="/AttendanceAdjustments/Index" class="btn btn-outline" style="min-width: 100px;">X Hủy</a>
        <button type="submit" class="btn btn-primary" style="min-width: 160px;">
            <i class="bi bi-floppy-fill me-1"></i> Cập nhật
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calcProposedWorkingHours() {
            var inVal = document.getElementById('reqCheckInInput').value;
            var outVal = document.getElementById('reqCheckOutInput').value;

            if (inVal && outVal) {
                var dIn = new Date(inVal);
                var dOut = new Date(outVal);
                var diffMs = dOut - dIn;
                if (diffMs > 0) {
                    var diffHrs = (diffMs / (1000 * 60 * 60)).toFixed(2);
                    document.getElementById('proposedHoursDisplay').innerText = diffHrs + ' giờ';
                    return;
                }
            }
            document.getElementById('proposedHoursDisplay').innerText = '-- giờ';
        }

        document.addEventListener("DOMContentLoaded", function() {
            calcProposedWorkingHours();
        });
    </script>
}
