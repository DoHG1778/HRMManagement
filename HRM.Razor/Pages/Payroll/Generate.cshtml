@page
@model HRM.Razor.Pages.Payroll.GenerateModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Tạo bảng lương tháng";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/payroll.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Tiền lương &gt; <span>Tạo bảng lương</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Tạo bảng lương tháng</h1>
        <p class="page-subtitle mb-0">Tạo bảng lương nháp để tính lương cho nhân viên trong tháng</p>
    </div>

    <a asp-page="/Payroll/Index" class="btn btn-outline">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<!-- Steps Wizard (Matching Mockup UC30) -->
<div class="payroll-wizard-steps">
    <div class="wizard-step-item active">
        <div class="wizard-step-number">1</div>
        <div>
            <div style="font-size: 0.85rem; text-transform: uppercase;">Bước 1</div>
            <div>Chọn kỳ lương</div>
        </div>
    </div>
    <div class="wizard-step-item">
        <div class="wizard-step-number">2</div>
        <div>
            <div style="font-size: 0.85rem; text-transform: uppercase;">Bước 2</div>
            <div>Xác nhận nhân viên</div>
        </div>
    </div>
    <div class="wizard-step-item">
        <div class="wizard-step-number">3</div>
        <div>
            <div style="font-size: 0.85rem; text-transform: uppercase;">Bước 3</div>
            <div>Tạo bảng lương</div>
        </div>
    </div>
</div>

<div class="row g-4" style="display: grid; grid-template-columns: 1fr 360px; gap: 1.5rem;">
    <!-- Left Column: Form -->
    <div>
        <div class="card" style="padding: 2rem;">
            <form method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                    </div>
                }

                <div class="form-section-title mb-3">
                    <i class="bi bi-calendar-check"></i> 1. Chọn kỳ lương
                </div>

                <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label asp-for="Input.PayrollMonth" class="form-label required-label"></label>
                        <select asp-for="Input.PayrollMonth" class="form-control" id="monthSelect" onchange="updatePeriodDates()">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">Tháng @m</option>
                            }
                        </select>
                        <span asp-validation-for="Input.PayrollMonth" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="Input.PayrollYear" class="form-label required-label"></label>
                        <select asp-for="Input.PayrollYear" class="form-control" id="yearSelect" onchange="updatePeriodDates()">
                            @for (int y = 2024; y <= 2026; y++)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                        <span asp-validation-for="Input.PayrollYear" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label class="form-label text-muted">Ngày bắt đầu kỳ</label>
                        <input type="text" id="startDatePreview" class="form-control" readonly style="background-color: #f1f5f9; color: #64748b;" />
                    </div>

                    <div>
                        <label class="form-label text-muted">Ngày kết thúc kỳ</label>
                        <input type="text" id="endDatePreview" class="form-control" readonly style="background-color: #f1f5f9; color: #64748b;" />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.DepartmentId" class="form-label"></label>
                    <select asp-for="Input.DepartmentId" asp-items="Model.DepartmentOptions" class="form-control"></select>
                </div>

                <div class="form-group mb-3">
                    <div class="form-check">
                        <input asp-for="Input.OnlyActiveEmployees" class="form-check-input" type="checkbox" id="onlyActiveCheck" checked disabled />
                        <label class="form-check-label" for="onlyActiveCheck">
                            Chỉ bao gồm nhân viên đang làm việc (ACTIVE) có hợp đồng hợp lệ
                        </label>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-end gap-2" style="margin-top: 2rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
                    <a asp-page="/Payroll/Index" class="btn btn-outline" style="min-width: 100px;">Hủy</a>
                    <button type="submit" class="btn btn-primary" style="min-width: 170px;">
                        <i class="bi bi-check-circle-fill me-1"></i> Tạo bảng lương nháp
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Notes & Quick Stats (Matching Mockup UC30) -->
    <div>
        <div class="card mb-4" style="padding: 1.25rem;">
            <div class="form-section-title mb-3" style="font-size: 0.95rem;">
                <i class="bi bi-info-circle"></i> Lưu ý
            </div>
            <ul class="mb-0 ps-3 text-muted" style="font-size: 0.85rem; line-height: 1.6;">
                <li class="mb-2">Mỗi nhân viên chỉ có một bảng lương cho mỗi tháng và năm.</li>
                <li class="mb-2">Bảng lương sau khi tạo sẽ ở trạng thái <strong>DRAFT</strong>.</li>
                <li class="mb-2">Bạn có thể chỉnh sửa chi tiết bảng lương trước khi xác nhận.</li>
                <li>Chỉ các khoản tăng ca đã được duyệt mới được tự động tính vào lương.</li>
            </ul>
        </div>

        <div class="card" style="padding: 1.25rem;">
            <div class="form-section-title mb-3" style="font-size: 0.95rem;">
                <i class="bi bi-shield-check"></i> Quy trình tạo bảng lương
            </div>
            <div class="d-flex flex-column gap-2" style="font-size: 0.85rem; color: #475569;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-1-circle-fill text-primary" style="font-size: 1.1rem;"></i>
                    <span>Tạo danh sách bảng lương nháp (DRAFT)</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-2-circle-fill text-primary" style="font-size: 1.1rem;"></i>
                    <span>Tính lương tự động (Lương cơ bản + OT)</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-3-circle-fill text-primary" style="font-size: 1.1rem;"></i>
                    <span>Kiểm tra & Cập nhật các khoản điều chỉnh</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updatePeriodDates() {
            var month = document.getElementById('monthSelect').value;
            var year = document.getElementById('yearSelect').value;
            if (month && year) {
                var m = String(month).padStart(2, '0');
                var lastDay = new Date(year, month, 0).getDate();
                document.getElementById('startDatePreview').value = '01/' + m + '/' + year;
                document.getElementById('endDatePreview').value = String(lastDay).padStart(2, '0') + '/' + m + '/' + year;
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            updatePeriodDates();
        });
    </script>
}
