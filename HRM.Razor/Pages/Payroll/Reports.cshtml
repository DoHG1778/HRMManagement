@page
@model HRM.Razor.Pages.Payroll.ReportsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Báo cáo bảng lương";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/payroll.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Tiền lương &gt; <span>Báo cáo lương</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">Báo cáo bảng lương</h1>
        <p class="page-subtitle mb-0">Xem báo cáo tổng hợp quỹ lương và xuất dữ liệu theo kỳ</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="/Payroll/Index" class="btn btn-outline">
            <i class="bi bi-arrow-left me-1"></i> Danh sách bảng lương
        </a>
        <a asp-page-handler="ExportCsv" asp-route-month="@Model.Month" asp-route-year="@Model.Year" asp-route-departmentId="@Model.DepartmentId" class="btn btn-success">
            <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel / CSV
        </a>
    </div>
</div>

<!-- Filter Bar (Matching Mockup UC35) -->
<div class="card mb-4" style="padding: 1.25rem;">
    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
        <div style="width: 130px;">
            <select asp-for="Month" class="form-control">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">Tháng @m</option>
                }
            </select>
        </div>

        <div style="width: 130px;">
            <select asp-for="Year" class="form-control">
                @for (int y = 2024; y <= 2026; y++)
                {
                    <option value="@y">Năm @y</option>
                }
            </select>
        </div>

        <div style="width: 200px;">
            <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-control"></select>
        </div>

        <button type="submit" class="btn btn-primary" style="height: 42px;">
            <i class="bi bi-funnel me-1"></i> Xem báo cáo
        </button>
    </form>
</div>

<!-- Summary Metrics Bar (Matching Mockup UC35) -->
<div class="row g-3 mb-4" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem;">
    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i class="bi bi-people"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.78rem; font-weight: 600;">Tổng nhân viên</div>
            <div style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">@Model.Report.TotalEmployees</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #f8fafc; color: #475569; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i class="bi bi-cash-stack"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.78rem; font-weight: 600;">Tổng lương cơ bản</div>
            <div style="font-size: 1.15rem; font-weight: 700; color: #0f172a;">@Model.Report.TotalBaseSalary.ToString("N0") ₫</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #f0fdf4; color: #166534; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i class="bi bi-wallet2"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.78rem; font-weight: 600;">Tổng thu nhập (Gross)</div>
            <div style="font-size: 1.15rem; font-weight: 700; color: #166534;">@Model.Report.TotalGrossSalary.ToString("N0") ₫</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #fef2f2; color: #991b1b; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i class="bi bi-dash-circle"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.78rem; font-weight: 600;">Tổng khấu trừ</div>
            <div style="font-size: 1.15rem; font-weight: 700; color: #991b1b;">@Model.Report.TotalDeduction.ToString("N0") ₫</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #eff6ff; color: #1d4ed8; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.78rem; font-weight: 600;">Thực lĩnh (Net)</div>
            <div style="font-size: 1.2rem; font-weight: 800; color: #1d4ed8;">@Model.Report.TotalNetSalary.ToString("N0") ₫</div>
        </div>
    </div>
</div>

<!-- Tabs Navigation & Tables (Matching Mockup UC35) -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="card-header bg-white border-bottom p-0">
        <ul class="nav nav-tabs px-3 pt-2 border-0" id="reportTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="dept-tab" data-bs-toggle="tab" data-bs-target="#dept-tab-pane" type="button" role="tab" aria-controls="dept-tab-pane" aria-selected="true" style="border: none; border-bottom: 3px solid #2563eb; color: #2563eb; padding: 0.85rem 1.25rem;">
                    <i class="bi bi-building me-1"></i> Tổng quan theo phòng ban
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-muted" id="emp-tab" data-bs-toggle="tab" data-bs-target="#emp-tab-pane" type="button" role="tab" aria-controls="emp-tab-pane" aria-selected="false" style="border: none; padding: 0.85rem 1.25rem;">
                    <i class="bi bi-person-lines-fill me-1"></i> Chi tiết nhân viên
                </button>
            </li>
        </ul>
    </div>

    <div class="tab-content" id="reportTabContent">
        <!-- Tab 1: Tổng quan theo phòng ban (Matching Mockup UC35) -->
        <div class="tab-pane fade show active" id="dept-tab-pane" role="tabpanel" aria-labelledby="dept-tab" tabindex="0">
            <div class="table-responsive">
                <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
                    <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                        <tr>
                            <th style="padding: 0.85rem 1rem; width: 50px;">STT</th>
                            <th style="padding: 0.85rem 1rem;">Phòng ban</th>
                            <th style="padding: 0.85rem 1rem; text-align: center;">Số nhân viên</th>
                            <th style="padding: 0.85rem 1rem; text-align: right;">Tổng lương cơ bản</th>
                            <th style="padding: 0.85rem 1rem; text-align: right;">Tổng thu nhập (Gross)</th>
                            <th style="padding: 0.85rem 1rem; text-align: right;">Tổng khấu trừ</th>
                            <th style="padding: 0.85rem 1rem; text-align: right;">Thực lĩnh (Net)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Report.DepartmentSummaries != null && Model.Report.DepartmentSummaries.Any())
                        {
                            int index = 1;
                            foreach (var dept in Model.Report.DepartmentSummaries)
                            {
                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                    <td style="padding: 0.85rem 1rem; color: #64748b;">@index</td>
                                    <td style="padding: 0.85rem 1rem; font-weight: 700; color: #0f172a;">@dept.DepartmentName</td>
                                    <td style="padding: 0.85rem 1rem; text-align: center; font-weight: 600;">@dept.EmployeeCount</td>
                                    <td style="padding: 0.85rem 1rem; text-align: right;">@dept.TotalBaseSalary.ToString("N0") ₫</td>
                                    <td style="padding: 0.85rem 1rem; text-align: right; color: #166534; font-weight: 600;">@dept.TotalGrossSalary.ToString("N0") ₫</td>
                                    <td style="padding: 0.85rem 1rem; text-align: right; color: #dc2626;">@dept.TotalDeduction.ToString("N0") ₫</td>
                                    <td style="padding: 0.85rem 1rem; text-align: right; font-weight: 700; color: #2563eb;">@dept.TotalNetSalary.ToString("N0") ₫</td>
                                </tr>
                                index++;
                            }
                            <!-- Dòng Tổng cộng -->
                            <tr style="background-color: #f8fafc; font-weight: 700; border-top: 2px solid #cbd5e1;">
                                <td colspan="2" style="padding: 1rem; text-transform: uppercase; color: #0f172a;">Tổng cộng</td>
                                <td style="padding: 1rem; text-align: center; color: #0f172a;">@Model.Report.TotalEmployees</td>
                                <td style="padding: 1rem; text-align: right;">@Model.Report.TotalBaseSalary.ToString("N0") ₫</td>
                                <td style="padding: 1rem; text-align: right; color: #166534;">@Model.Report.TotalGrossSalary.ToString("N0") ₫</td>
                                <td style="padding: 1rem; text-align: right; color: #dc2626;">@Model.Report.TotalDeduction.ToString("N0") ₫</td>
                                <td style="padding: 1rem; text-align: right; color: #1d4ed8; font-size: 1.05rem;">@Model.Report.TotalNetSalary.ToString("N0") ₫</td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted" style="padding: 2.5rem 1rem;">
                                    Chưa có dữ liệu báo cáo cho kỳ lương này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab 2: Chi tiết nhân viên -->
        <div class="tab-pane fade" id="emp-tab-pane" role="tabpanel" aria-labelledby="emp-tab" tabindex="0">
            <div class="table-responsive">
                <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.84rem;">
                    <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                        <tr>
                            <th style="padding: 0.75rem 0.85rem; width: 40px;">STT</th>
                            <th style="padding: 0.75rem 0.85rem;">Nhân viên</th>
                            <th style="padding: 0.75rem 0.85rem;">Phòng ban</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Lương cơ bản</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Phụ cấp</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Thưởng</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Tăng ca</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Gross</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Khấu trừ</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: right;">Thực lĩnh</th>
                            <th style="padding: 0.75rem 0.85rem; text-align: center;">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Report.Payrolls != null && Model.Report.Payrolls.Any())
                        {
                            int index = 1;
                            foreach (var item in Model.Report.Payrolls)
                            {
                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                    <td style="padding: 0.75rem 0.85rem; color: #64748b;">@index</td>
                                    <td style="padding: 0.75rem 0.85rem; font-weight: 700; color: #0f172a;">@item.EmployeeCode - @item.EmployeeName</td>
                                    <td style="padding: 0.75rem 0.85rem; color: #475569;">@(item.DepartmentName ?? "Chưa phân công")</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right;">@item.BaseSalary.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; color: #166534;">@item.TotalAllowance.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; color: #7e22ce;">@item.TotalBonus.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; color: #2563eb;">@item.TotalOvertime.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; font-weight: 600;">@item.GrossSalary.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; color: #dc2626;">@item.TotalDeduction.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: right; font-weight: 700; color: #1d4ed8;">@item.NetSalary.ToString("N0") ₫</td>
                                    <td style="padding: 0.75rem 0.85rem; text-align: center;">
                                        <span class="badge bg-success" style="font-size: 0.7rem;">@item.Status</span>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
