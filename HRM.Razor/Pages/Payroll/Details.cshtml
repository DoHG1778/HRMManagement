@page "{id:int}"
@model HRM.Razor.Pages.Payroll.DetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Chi tiết bảng lương - {Model.Payroll.EmployeeName}";
    ViewData["ActivePage"] = "PayrollIndex";

    var statusBadgeClass = Model.Payroll.Status switch
    {
        "CONFIRMED" => "badge-confirmed",
        "PAID" => "badge-paid",
        _ => "badge-draft"
    };

    var statusText = Model.Payroll.Status switch
    {
        "CONFIRMED" => "Đã chốt (CONFIRMED)",
        "PAID" => "Đã chi trả (PAID)",
        _ => "Nháp (DRAFT)"
    };
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/payroll.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Tiền lương &gt; Chi tiết bảng lương &gt; <span>@(Model.IsDraft ? "Chỉnh sửa chi tiết lương" : "Xem chi tiết lương")</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">@(Model.IsDraft ? "Chỉnh sửa chi tiết lương" : "Chi tiết bảng lương (Đã chốt)")</h1>
        <p class="page-subtitle mb-0">Cập nhật và kiểm tra các khoản thu nhập, khấu trừ của nhân viên</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="/Payroll/Index" class="btn btn-outline">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        @if (Model.IsDraft)
        {
            <button type="button" class="btn btn-primary" onclick="submitSavePayrollDetails()">
                <i class="bi bi-floppy-fill me-1"></i> Lưu thay đổi
            </button>
        }
    </div>
</div>

<!-- Header Card Tóm tắt thông tin nhân viên (Matching Mockup UC32) -->
<div class="card mb-4" style="padding: 1.5rem;">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 56px; height: 56px; border-radius: 50%; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.25rem;">
                @(Model.Payroll.EmployeeName.Length > 0 ? Model.Payroll.EmployeeName.Substring(0, 1).ToUpper() : "E")
            </div>
            <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <h3 class="mb-0" style="font-size: 1.2rem; font-weight: 700; color: #0f172a;">@Model.Payroll.EmployeeCode - @Model.Payroll.EmployeeName</h3>
                    <span class="@statusBadgeClass">@statusText</span>
                </div>
                <div class="text-muted" style="font-size: 0.85rem;">
                    Phòng ban: <strong>@(Model.Payroll.DepartmentName ?? "Chưa phân công")</strong> | Chức vụ: <strong>@(Model.Payroll.PositionName ?? "Chưa phân công")</strong>
                </div>
            </div>
        </div>

        <div class="d-flex align-items-center gap-4 text-muted" style="font-size: 0.88rem;">
            <div>Kỳ lương: <strong class="text-primary">Tháng @Model.Payroll.PayrollMonth/@Model.Payroll.PayrollYear</strong></div>
            <div>Ngày công chuẩn: <strong>24 ngày</strong></div>
        </div>
    </div>
</div>

@if (!Model.IsDraft)
{
    <div class="alert alert-warning mb-4" role="alert">
        <i class="bi bi-lock-fill me-2"></i>
        <strong>Bảng lương đã chốt:</strong> Bảng lương này ở trạng thái <strong>@Model.Payroll.Status</strong> nên không thể tiếp tục chỉnh sửa các khoản thu nhập / khấu trừ.
    </div>
}

<form method="post" asp-page-handler="SaveDetails" id="saveDetailsForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="itemsJson" id="itemsJsonInput" />
</form>

<!-- 3-Column Layout (Matching Mockup UC32) -->
<div class="payroll-3col-grid">
    <!-- Column 1: Thu nhập -->
    <div class="payroll-detail-card">
        <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
            <h5 class="mb-0" style="font-size: 1rem; font-weight: 700; color: #1e40af;">
                <i class="bi bi-wallet2 me-1"></i> 1. Thu nhập
            </h5>
            @if (Model.IsDraft)
            {
                <button type="button" class="btn btn-sm btn-outline" onclick="openAddItemModal('ALLOWANCE')">
                    <i class="bi bi-plus me-1"></i> Thêm khoản
                </button>
            }
        </div>

        <div class="payroll-detail-row">
            <div>
                <strong style="color: #0f172a;">Lương cơ bản *</strong>
                <div class="text-muted" style="font-size: 0.78rem;">Theo hợp đồng lao động</div>
            </div>
            <strong style="color: #0f172a;">@Model.Payroll.BaseSalary.ToString("N0") ₫</strong>
        </div>

        <div id="incomeItemsContainer">
            <!-- Dynamic JS rendered items -->
        </div>

        <div class="d-flex align-items-center justify-content-between mt-3 pt-3 border-top" style="background-color: #f0fdf4; padding: 0.85rem; border-radius: 10px;">
            <strong style="color: #166534;">Tổng thu nhập (Gross)</strong>
            <strong style="font-size: 1.1rem; color: #166534;" id="grossTotalDisplay">@Model.Payroll.GrossSalary.ToString("N0") ₫</strong>
        </div>
    </div>

    <!-- Column 2: Khoản trừ -->
    <div class="payroll-detail-card">
        <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
            <h5 class="mb-0" style="font-size: 1rem; font-weight: 700; color: #b91c1c;">
                <i class="bi bi-dash-circle me-1"></i> 2. Khoản trừ
            </h5>
            @if (Model.IsDraft)
            {
                <button type="button" class="btn btn-sm btn-outline" onclick="openAddItemModal('DEDUCTION')">
                    <i class="bi bi-plus me-1"></i> Thêm khoản trừ
                </button>
            }
        </div>

        <div id="deductionItemsContainer">
            <!-- Dynamic JS rendered items -->
        </div>

        <div class="d-flex align-items-center justify-content-between mt-3 pt-3 border-top" style="background-color: #fef2f2; padding: 0.85rem; border-radius: 10px;">
            <strong style="color: #991b1b;">Tổng khoản trừ</strong>
            <strong style="font-size: 1.1rem; color: #991b1b;" id="deductionTotalDisplay">@Model.Payroll.TotalDeduction.ToString("N0") ₫</strong>
        </div>
    </div>

    <!-- Column 3: Kết quả & Ghi chú -->
    <div>
        <div class="payroll-detail-card mb-4">
            <div class="form-section-title mb-3" style="font-size: 0.95rem;">
                <i class="bi bi-check2-circle"></i> 3. Kết quả
            </div>

            <div class="d-flex justify-content-between mb-2" style="font-size: 0.9rem;">
                <span class="text-muted">Tổng thu nhập:</span>
                <span id="summaryGross">@Model.Payroll.GrossSalary.ToString("N0") ₫</span>
            </div>
            <div class="d-flex justify-content-between mb-2" style="font-size: 0.9rem;">
                <span class="text-muted">Tổng khoản trừ:</span>
                <span class="text-danger" id="summaryDeduction">- @Model.Payroll.TotalDeduction.ToString("N0") ₫</span>
            </div>

            <div class="d-flex align-items-center justify-content-between mt-3 pt-3 border-top" style="background-color: #eff6ff; padding: 1rem; border-radius: 12px;">
                <strong style="color: #1e40af;">Lương thực nhận (Net)</strong>
                <strong style="font-size: 1.3rem; color: #1d4ed8;" id="summaryNet">@Model.Payroll.NetSalary.ToString("N0") ₫</strong>
            </div>
        </div>

        <div class="card" style="padding: 1.25rem;">
            <div class="form-section-title mb-2" style="font-size: 0.9rem;">
                <i class="bi bi-info-circle"></i> Lưu ý
            </div>
            <p style="font-size: 0.82rem; color: #64748b; line-height: 1.6; margin: 0;">
                Chỉ có thể chỉnh sửa chi tiết thu nhập / khấu trừ khi bảng lương ở trạng thái <strong>DRAFT</strong>. Các khoản OT tự động không thể xóa thủ công.
            </p>
        </div>
    </div>
</div>

<partial name="Partials/_PayrollItemModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var isDraft = @(Model.IsDraft.ToString().ToLower());
        var baseSalary = @Model.Payroll.BaseSalary;

        // Initial items list from backend
        var currentItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Payroll.PayrollDetails ?? new List<HRM.Razor.Models.ViewModels.Payroll.PayrollDetailItemModel>()));

        function renderDetailsUI() {
            var incomeContainer = document.getElementById('incomeItemsContainer');
            var deductionContainer = document.getElementById('deductionItemsContainer');

            incomeContainer.innerHTML = '';
            deductionContainer.innerHTML = '';

            var totalGross = baseSalary;
            var totalDeduction = 0;

            currentItems.forEach(function(item, idx) {
                var type = item.ItemType ? item.ItemType.toUpperCase() : 'OTHER';
                var amt = item.Amount || 0;
                var isAuto = item.SourceType === 'SYSTEM' || item.SourceType === 'OVERTIME';

                var rowDiv = document.createElement('div');
                rowDiv.className = 'payroll-detail-row';

                var descDiv = '<div><span style="font-weight: 600;">' + (item.Description || type) + '</span>';
                if (isAuto) {
                    descDiv += ' <span class="badge bg-light text-secondary" style="font-size: 0.7rem;">Tự động</span>';
                }
                descDiv += '</div>';

                var actionBtn = '';
                if (isDraft && !isAuto) {
                    actionBtn = ' <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" onclick="removeItem(' + idx + ')" title="Xóa"><i class="bi bi-trash"></i></button>';
                }

                var amtDiv = '<div><strong style="font-size: 0.9rem;">' + amt.toLocaleString('vi-VN') + ' ₫</strong>' + actionBtn + '</div>';

                rowDiv.innerHTML = descDiv + amtDiv;

                if (type === 'DEDUCTION') {
                    totalDeduction += amt;
                    deductionContainer.appendChild(rowDiv);
                } else {
                    totalGross += amt;
                    incomeContainer.appendChild(rowDiv);
                }
            });

            if (deductionContainer.children.length === 0) {
                deductionContainer.innerHTML = '<div class="text-muted text-center py-3" style="font-size: 0.85rem;">Chưa có khoản khấu trừ nào.</div>';
            }

            var totalNet = totalGross - totalDeduction;
            if (totalNet < 0) totalNet = 0;

            document.getElementById('grossTotalDisplay').innerText = totalGross.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('deductionTotalDisplay').innerText = totalDeduction.toLocaleString('vi-VN') + ' ₫';

            document.getElementById('summaryGross').innerText = totalGross.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('summaryDeduction').innerText = '- ' + totalDeduction.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('summaryNet').innerText = totalNet.toLocaleString('vi-VN') + ' ₫';
        }

        function openAddItemModal(defaultType) {
            document.getElementById('itemEditIndex').value = '-1';
            document.getElementById('itemTypeSelect').value = defaultType || 'ALLOWANCE';
            document.getElementById('itemDescriptionInput').value = '';
            document.getElementById('itemAmountInput').value = '';

            var modal = new bootstrap.Modal(document.getElementById('payrollItemModal'));
            modal.show();
        }

        document.getElementById('savePayrollItemBtn').addEventListener('click', function() {
            var type = document.getElementById('itemTypeSelect').value;
            var desc = document.getElementById('itemDescriptionInput').value.trim();
            var amt = parseFloat(document.getElementById('itemAmountInput').value);

            if (!desc) {
                alert('Vui lòng nhập mô tả cho khoản chi tiết.');
                return;
            }
            if (isNaN(amt) || amt <= 0) {
                alert('Vui lòng nhập số tiền hợp lệ (> 0).');
                return;
            }

            currentItems.push({
                DetailId: 0,
                PayrollId: @Model.Payroll.PayrollId,
                ItemType: type,
                Amount: amt,
                Description: desc,
                SourceType: 'MANUAL',
                SourceId: null
            });

            renderDetailsUI();

            var modalEl = document.getElementById('payrollItemModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
        });

        function removeItem(index) {
            if (confirm('Xác nhận xóa khoản chi tiết này?')) {
                currentItems.splice(index, 1);
                renderDetailsUI();
            }
        }

        function submitSavePayrollDetails() {
            document.getElementById('itemsJsonInput').value = JSON.stringify(currentItems);
            document.getElementById('saveDetailsForm').submit();
        }

        document.addEventListener("DOMContentLoaded", function() {
            renderDetailsUI();
        });
    </script>
}
