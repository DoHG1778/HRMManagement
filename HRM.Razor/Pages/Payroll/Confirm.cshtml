@page
@model HRM.Razor.Pages.Payroll.ConfirmModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chốt bảng lương";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/payroll.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Tiền lương &gt; <span>Chốt bảng lương</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">Chốt bảng lương</h1>
        <p class="page-subtitle mb-0">Xác nhận bảng lương đã được kiểm tra và khóa chỉnh sửa cho kỳ lương</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="/Payroll/Index" class="btn btn-outline">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <a asp-page="/Payroll/Calculate" asp-route-month="@Model.Month" asp-route-year="@Model.Year" class="btn btn-outline">
            <i class="bi bi-calculator me-1"></i> Tính lương
        </a>
        @if (Model.DraftCount > 0)
        {
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmPayrollModal">
                <i class="bi bi-lock-fill me-1"></i> Chốt bảng lương
            </button>
        }
    </div>
</div>

<!-- Period Summary Header Card (Matching Mockup UC33) -->
<div class="card mb-4" style="padding: 1.5rem;">
    <div class="row g-4 align-items-center" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 44px; height: 44px; border-radius: 12px; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="bi bi-calendar3"></i>
            </div>
            <div>
                <div class="text-muted" style="font-size: 0.78rem;">Kỳ lương</div>
                <strong style="font-size: 1.05rem; color: #0f172a;">Tháng @Model.Month.ToString("D2")/@Model.Year</strong>
            </div>
        </div>

        <div>
            <div class="text-muted" style="font-size: 0.78rem;">Trạng thái</div>
            @if (Model.DraftCount > 0)
            {
                <span class="badge-draft">DRAFT (Chưa chốt: @Model.DraftCount)</span>
            }
            else
            {
                <span class="badge-confirmed">CONFIRMED (Đã chốt)</span>
            }
        </div>

        <div>
            <div class="text-muted" style="font-size: 0.78rem;">Số nhân viên</div>
            <strong style="font-size: 1.05rem; color: #0f172a;">@Model.TotalEmployeesCount nhân viên</strong>
        </div>

        <div>
            <div class="text-muted" style="font-size: 0.78rem;">Tổng quỹ lương (Gross)</div>
            <strong style="font-size: 1.05rem; color: #166534;">@Model.TotalGrossSalarySum.ToString("N0") ₫</strong>
        </div>

        <div>
            <div class="text-muted" style="font-size: 0.78rem;">Tổng thực lĩnh (Net)</div>
            <strong style="font-size: 1.15rem; color: #2563eb;">@Model.TotalNetSalarySum.ToString("N0") ₫</strong>
        </div>
    </div>
</div>

<!-- Filter Bar -->
<div class="card mb-4" style="padding: 1.25rem;">
    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
        <div style="width: 120px;">
            <select asp-for="Month" class="form-control">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">Tháng @m</option>
                }
            </select>
        </div>

        <div style="width: 130px;">
            <select asp-for="Year" class="form-control">
                @for (int y = 2024; y <= 2026; y++)
                {
                    <option value="@y">Năm @y</option>
                }
            </select>
        </div>

        <div style="width: 200px;">
            <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-control"></select>
        </div>

        <button type="submit" class="btn btn-primary" style="height: 42px;">
            <i class="bi bi-funnel me-1"></i> Xem danh sách
        </button>
    </form>
</div>

<!-- Table Checklist (Matching Mockup UC33) -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.84rem;">
            <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                <tr>
                    <th style="padding: 0.75rem 0.85rem; width: 40px;">STT</th>
                    <th style="padding: 0.75rem 0.85rem;">Nhân viên</th>
                    <th style="padding: 0.75rem 0.85rem;">Phòng ban</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Lương cơ bản</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Phụ cấp</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Thưởng</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Tăng ca (OT)</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Tổng thu nhập</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Khấu trừ</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: right;">Thực lĩnh</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: center;">Trạng thái</th>
                    <th style="padding: 0.75rem 0.85rem; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Payrolls != null && Model.Payrolls.Any())
                {
                    int index = 1;
                    foreach (var item in Model.Payrolls)
                    {
                        var statusBadgeClass = item.Status switch
                        {
                            "CONFIRMED" => "badge-confirmed",
                            "PAID" => "badge-paid",
                            _ => "badge-draft"
                        };
                        var statusText = item.Status switch
                        {
                            "CONFIRMED" => "Đã chốt",
                            "PAID" => "Đã chi trả",
                            _ => "Sẵn sàng chốt"
                        };

                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 0.75rem 0.85rem; color: #64748b;">@index</td>
                            <td style="padding: 0.75rem 0.85rem; font-weight: 700; color: #0f172a;">
                                @item.EmployeeCode - @item.EmployeeName
                            </td>
                            <td style="padding: 0.75rem 0.85rem; color: #475569;">
                                @(item.DepartmentName ?? "Chưa phân công")
                            </td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right;">@item.BaseSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; color: #166534;">@item.TotalAllowance.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; color: #7e22ce;">@item.TotalBonus.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; color: #2563eb;">@item.TotalOvertime.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; font-weight: 600;">@item.GrossSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; color: #dc2626;">@item.TotalDeduction.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: right; font-weight: 700; color: #166534;">@item.NetSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.75rem 0.85rem; text-align: center;">
                                <span class="@statusBadgeClass" style="font-size: 0.72rem;">@statusText</span>
                            </td>
                            <td style="padding: 0.75rem 0.85rem; text-align: center;">
                                <a asp-page="/Payroll/Details" asp-route-id="@item.PayrollId" class="btn btn-outline" style="padding: 0.2rem 0.45rem; font-size: 0.75rem;" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted" style="padding: 2.5rem 1rem;">
                            Không tìm thấy bảng lương nháp nào để chốt trong kỳ đã chọn.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Confirmation (UC33) -->
<div class="modal fade" id="confirmPayrollModal" tabindex="-1" aria-labelledby="confirmPayrollModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
            <div class="modal-header" style="background-color: #fff7ed; border-bottom: 1px solid #ffedd5; padding: 1.25rem 1.5rem;">
                <h5 class="modal-header-title d-flex align-items-center gap-2" id="confirmPayrollModalLabel" style="font-size: 1.1rem; font-weight: 700; color: #c2410c; margin: 0;">
                    <i class="bi bi-exclamation-triangle-fill"></i> Xác nhận chốt bảng lương kỳ @Model.Month/@Model.Year
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <div class="alert alert-warning mb-3" style="font-size: 0.88rem;">
                    <strong>Cảnh báo quan trọng:</strong> Sau khi chốt, toàn bộ bảng lương của kỳ <strong>Tháng @Model.Month/@Model.Year</strong> sẽ chuyển sang trạng thái <strong>CONFIRMED</strong> và <strong>KHÔNG THỂ KHÔI PHỤC HOẶC CHỈNH SỬA THỦ CÔNG</strong>. Thông báo phiếu lương cũng sẽ tự động được gửi tới từng nhân viên.
                </div>

                <div class="card p-3 mb-3 bg-light border-0">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Số bảng lương nháp sẽ chốt:</span>
                        <strong class="text-primary">@Model.DraftCount bảng lương</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tổng quỹ lương (Gross):</span>
                        <strong>@Model.TotalGrossSalarySum.ToString("N0") ₫</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Tổng thực lĩnh (Net):</span>
                        <strong class="text-success">@Model.TotalNetSalarySum.ToString("N0") ₫</strong>
                    </div>
                </div>

                <form method="post" asp-page-handler="ConfirmPeriod" id="confirmPeriodForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Month" value="@Model.Month" />
                    <input type="hidden" name="Year" value="@Model.Year" />
                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="confirmCheck" required />
                        <label class="form-check-label" for="confirmCheck" style="font-size: 0.88rem; font-weight: 600;">
                            Tôi đã kiểm tra kỹ lưỡng toàn bộ số liệu và xác nhận chốt bảng lương kỳ này.
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="background-color: #f8fafc; border-top: 1px solid #e2e8f0; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" style="background-color: #ea580c; border-color: #ea580c;" onclick="document.getElementById('confirmPeriodForm').submit();">
                    <i class="bi bi-lock-fill me-1"></i> Xác nhận chốt bảng lương
                </button>
            </div>
        </div>
    </div>
</div>
