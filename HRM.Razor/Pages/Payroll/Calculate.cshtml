@page
@model HRM.Razor.Pages.Payroll.CalculateModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Tính lương theo kỳ";
    ViewData["ActivePage"] = "PayrollCalculate";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/payroll.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Tiền lương &gt; <span>Tính lương</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Tính lương theo kỳ</h1>
        <p class="page-subtitle mb-0">Tính toán tự động lương cơ bản, OT, phụ cấp, thưởng và khấu trừ cho các bảng lương nháp</p>
    </div>

    <a asp-page="/Payroll/Index" class="btn btn-outline">
        <i class="bi bi-arrow-left me-1"></i> Danh sách bảng lương
    </a>
</div>

<!-- Period Summary Cards (Matching Mockup UC31) -->
<div class="row g-3 mb-4" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 48px; height: 48px; border-radius: 12px; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
            <i class="bi bi-calendar-event"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.8rem; font-weight: 600;">Kỳ lương</div>
            <div style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">@Model.Input.PayrollMonth.ToString("D2")/@Model.Input.PayrollYear</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 48px; height: 48px; border-radius: 12px; background-color: #fef3c7; color: #d97706; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
            <i class="bi bi-pencil-square"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.8rem; font-weight: 600;">Trạng thái</div>
            <div style="font-size: 1.1rem; font-weight: 700; color: #d97706;">DRAFT (Chưa chốt)</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 48px; height: 48px; border-radius: 12px; background-color: #f1f5f9; color: #334155; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
            <i class="bi bi-people"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.8rem; font-weight: 600;">Tổng số bảng lương DRAFT</div>
            <div style="font-size: 1.25rem; font-weight: 700; color: #0f172a;">@Model.TotalDraftCount</div>
        </div>
    </div>

    <div class="card p-3 d-flex align-items-center flex-row gap-3">
        <div style="width: 48px; height: 48px; border-radius: 12px; background-color: #dcfce7; color: #166534; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
            <i class="bi bi-cash-stack"></i>
        </div>
        <div>
            <div class="text-muted" style="font-size: 0.8rem; font-weight: 600;">Tổng Net dự kiến</div>
            <div style="font-size: 1.2rem; font-weight: 700; color: #166534;">@Model.TotalNetSalarySum.ToString("N0") ₫</div>
        </div>
    </div>
</div>

<!-- Calculation Form Card (Matching Mockup UC31) -->
<div class="card mb-4" style="padding: 1.75rem;">
    <form method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-4" role="alert">
                <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
            </div>
        }

        <div class="form-section-title mb-3">
            <i class="bi bi-sliders"></i> Cài đặt công thức &amp; Thông số tính lương
        </div>

        <div class="payroll-settings-grid mb-3">
            <div>
                <label asp-for="Input.PayrollMonth" class="form-label required-label"></label>
                <select asp-for="Input.PayrollMonth" class="form-control">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m">Tháng @m</option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="Input.PayrollYear" class="form-label required-label"></label>
                <select asp-for="Input.PayrollYear" class="form-control">
                    @for (int y = 2024; y <= 2026; y++)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="Input.DepartmentId" class="form-label"></label>
                <select asp-for="Input.DepartmentId" asp-items="Model.DepartmentOptions" class="form-control"></select>
            </div>

            <div>
                <label asp-for="Input.OvertimeCoefficient" class="form-label required-label"></label>
                <input asp-for="Input.OvertimeCoefficient" type="number" step="0.1" class="form-control" placeholder="1.5" />
            </div>

            <div>
                <label asp-for="Input.StandardWorkingDays" class="form-label required-label"></label>
                <input asp-for="Input.StandardWorkingDays" type="number" class="form-control" placeholder="24" />
            </div>

            <div>
                <label asp-for="Input.StandardWorkingHoursPerDay" class="form-label required-label"></label>
                <input asp-for="Input.StandardWorkingHoursPerDay" type="number" class="form-control" placeholder="8" />
            </div>
        </div>

        <div class="payroll-defaults-grid mb-3">
            <div>
                <label asp-for="Input.DefaultAllowance" class="form-label"></label>
                <input asp-for="Input.DefaultAllowance" type="number" step="1000" class="form-control" placeholder="0" />
            </div>

            <div>
                <label asp-for="Input.DefaultBonus" class="form-label"></label>
                <input asp-for="Input.DefaultBonus" type="number" step="1000" class="form-control" placeholder="0" />
            </div>

            <div>
                <label asp-for="Input.DefaultDeduction" class="form-label"></label>
                <input asp-for="Input.DefaultDeduction" type="number" step="1000" class="form-control" placeholder="0" />
            </div>
        </div>

        <div class="d-flex align-items-center justify-content-between" style="margin-top: 1.5rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
            <div class="text-muted" style="font-size: 0.85rem;">
                <i class="bi bi-info-circle me-1"></i> Nguồn OT: Lấy từ các Đơn tăng ca có trạng thái <strong>APPROVED</strong> chưa chuyển lương trong kỳ.
            </div>

            <button type="submit" class="btn btn-primary" style="min-width: 180px; height: 42px;">
                <i class="bi bi-calculator-fill me-1"></i> Tính lương theo kỳ
            </button>
        </div>
    </form>
</div>

<!-- Table Preview DRAFT Payrolls -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="card-header bg-light p-3 border-bottom d-flex align-items-center justify-content-between">
        <h5 class="mb-0" style="font-size: 1rem; font-weight: 700; color: #0f172a;">
            <i class="bi bi-table me-1"></i> Danh sách bảng lương nháp kỳ @Model.Input.PayrollMonth/@Model.Input.PayrollYear
        </h5>
        <span class="badge badge-warning" style="font-size: 0.8rem;">DRAFT</span>
    </div>

    <div class="table-responsive">
        <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
            <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                <tr>
                    <th style="padding: 0.85rem 1rem; width: 50px;">STT</th>
                    <th style="padding: 0.85rem 1rem;">Mã &amp; Họ tên nhân viên</th>
                    <th style="padding: 0.85rem 1rem;">Phòng ban</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Lương cơ bản</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">OT</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Phụ cấp</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Thưởng</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Khấu trừ</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Lương Gross</th>
                    <th style="padding: 0.85rem 1rem; text-align: right;">Thực nhận (Net)</th>
                    <th style="padding: 0.85rem 1rem; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DraftPayrolls != null && Model.DraftPayrolls.Any())
                {
                    int index = 1;
                    foreach (var item in Model.DraftPayrolls)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 0.85rem 1rem; color: #64748b;">@index</td>
                            <td style="padding: 0.85rem 1rem; font-weight: 700; color: #0f172a;">
                                @item.EmployeeCode - @item.EmployeeName
                            </td>
                            <td style="padding: 0.85rem 1rem; color: #475569;">
                                @(item.DepartmentName ?? "Chưa phân công")
                            </td>
                            <td style="padding: 0.85rem 1rem; text-align: right;">@item.BaseSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; color: #2563eb;">@item.TotalOvertime.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; color: #166534;">@item.TotalAllowance.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; color: #7e22ce;">@item.TotalBonus.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; color: #dc2626;">@item.TotalDeduction.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; font-weight: 600;">@item.GrossSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: right; font-weight: 700; color: #166534;">@item.NetSalary.ToString("N0") ₫</td>
                            <td style="padding: 0.85rem 1rem; text-align: center;">
                                <a asp-page="/Payroll/Details" asp-route-id="@item.PayrollId" class="btn btn-outline" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;" title="Xem & Chỉnh sửa chi tiết">
                                    <i class="bi bi-pencil"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="text-center text-muted" style="padding: 2.5rem 1rem;">
                            <i class="bi bi-inbox" style="font-size: 1.8rem; color: #cbd5e1; display: block; margin-bottom: 0.5rem;"></i>
                            Không có bảng lương nháp (DRAFT) nào cho kỳ lương này. Vui lòng bấm nút <strong>Tạo bảng lương tháng</strong> để khởi tạo.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
