@page
@model HRM.Razor.Pages.Employees.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý hồ sơ nhân viên";

    bool canManage = User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("HR Staff") || User.IsInRole("System Administrator");
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Nhân sự &gt; <span>Hồ sơ nhân viên</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-1">Quản lý hồ sơ nhân viên</h1>
        <p class="page-subtitle mb-0">Quản lý danh sách nhân viên, thông tin cá nhân và trạng thái làm việc</p>
    </div>

    @if (canManage)
    {
        <a asp-page="/Employees/Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-1"></i> Tạo hồ sơ mới
        </a>
    }
</div>

<!-- Filter Bar -->
<div class="card mb-4" style="padding: 1.25rem;">
    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
        <div style="flex: 1; min-width: 240px; position: relative;">
            <input type="text" asp-for="Keyword" class="form-control" placeholder="Tìm kiếm theo mã NV, họ tên, email..." style="padding-right: 2.2rem;" />
            <i class="bi bi-search" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8;"></i>
        </div>

        <div style="width: 200px;">
            <select asp-for="Status" class="form-control">
                <option value="">Tất cả trạng thái</option>
                <option value="ACTIVE">Đang làm việc</option>
                <option value="ON_LEAVE">Đang nghỉ</option>
                <option value="RESIGNED">Đã nghỉ việc</option>
                <option value="TERMINATED">Đã chấm dứt</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary" style="height: 42px;">
            <i class="bi bi-funnel me-1"></i> Lọc
        </button>
        <a asp-page="/Employees/Index" class="btn btn-outline" style="height: 42px;">Làm mới</a>
    </form>
</div>

<!-- Table Container -->
<div class="card" style="padding: 0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table mb-0" style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
            <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left;">
                <tr>
                    <th style="padding: 1rem 1.25rem;">Mã NV</th>
                    <th style="padding: 1rem 1.25rem;">Họ và tên</th>
                    <th style="padding: 1rem 1.25rem;">Giới tính</th>
                    <th style="padding: 1rem 1.25rem;">Email</th>
                    <th style="padding: 1rem 1.25rem;">SĐT</th>
                    <th style="padding: 1rem 1.25rem;">Ngày vào làm</th>
                    <th style="padding: 1rem 1.25rem;">Trạng thái</th>
                    <th style="padding: 1rem 1.25rem; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees?.Items != null && Model.Employees.Items.Any())
                {
                    foreach (var emp in Model.Employees.Items)
                    {
                        var statusClass = emp.EmploymentStatus switch
                        {
                            "ACTIVE" => "badge-status-active",
                            "ON_LEAVE" => "badge-status-onleave",
                            "RESIGNED" => "badge-status-resigned",
                            "TERMINATED" => "badge-status-terminated",
                            _ => "badge-status-active"
                        };

                        var statusText = emp.EmploymentStatus switch
                        {
                            "ACTIVE" => "Đang làm việc",
                            "ON_LEAVE" => "Đang nghỉ",
                            "RESIGNED" => "Đã nghỉ việc",
                            "TERMINATED" => "Đã chấm dứt",
                            _ => emp.EmploymentStatus
                        };

                        <tr style="border-bottom: 1px solid #f1f5f9; transition: background-color 0.2s ease;">
                            <td style="padding: 1rem 1.25rem; font-weight: 700; color: #2563eb;">
                                @emp.EmployeeCode
                            </td>
                            <td style="padding: 1rem 1.25rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width: 32px; height: 32px; border-radius: 50%; background-color: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem;">
                                        @(string.IsNullOrEmpty(emp.FullName) ? "U" : emp.FullName.Substring(0, 1).ToUpper())
                                    </div>
                                    <strong>@emp.FullName</strong>
                                </div>
                            </td>
                            <td style="padding: 1rem 1.25rem;">@emp.Gender</td>
                            <td style="padding: 1rem 1.25rem;">@emp.Email</td>
                            <td style="padding: 1rem 1.25rem;">@(emp.Phone ?? "-")</td>
                            <td style="padding: 1rem 1.25rem;">@emp.HireDate.ToString("dd/MM/yyyy")</td>
                            <td style="padding: 1rem 1.25rem;">
                                <span class="badge-status @statusClass">@statusText</span>
                            </td>
                            <td style="padding: 1rem 1.25rem; text-align: right;">
                                <a asp-page="/Employees/Details" asp-route-id="@emp.EmployeeId" class="btn btn-outline" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; margin-right: 0.3rem;" title="Xem chi tiết">
                                    <i class="bi bi-eye me-1"></i> Chi tiết
                                </a>
                                @if (canManage)
                                {
                                    <a asp-page="/Employees/Edit" asp-route-id="@emp.EmployeeId" class="btn btn-outline" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;" title="Chỉnh sửa">
                                        <i class="bi bi-pencil me-1"></i> Sửa
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted" style="padding: 3rem 1rem;">
                            <i class="bi bi-inbox" style="font-size: 2rem; color: #cbd5e1; display: block; margin-bottom: 0.5rem;"></i>
                            Không tìm thấy hồ sơ nhân viên nào phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Footer -->
    @if (Model.Employees != null && Model.Employees.TotalPages > 1)
    {
        <div style="padding: 1rem 1.25rem; background-color: #f8fafc; border-top: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: space-between;">
            <div class="text-muted" style="font-size: 0.85rem;">
                Hiển thị @(Model.Employees.Items?.Count ?? 0) trong số @Model.Employees.TotalItems nhân viên
            </div>
            <div class="d-flex gap-1">
                @for (int i = 1; i <= Model.Employees.TotalPages; i++)
                {
                    <a asp-page="/Employees/Index" asp-route-pageNumber="@i" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status" class="btn @(i == Model.Employees.PageNumber ? "btn-primary" : "btn-outline")" style="padding: 0.3rem 0.75rem; font-size: 0.85rem;">
                        @i
                    </a>
                }
            </div>
        </div>
    }
</div>
