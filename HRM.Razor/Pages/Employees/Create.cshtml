@page
@model HRM.Razor.Pages.Employees.CreateModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Tạo hồ sơ nhân viên";
}

<link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />

<div class="page-breadcrumb">
    Nhân sự &gt; Hồ sơ nhân viên &gt; <span>Tạo hồ sơ</span>
</div>

<div class="page-title-block">
    <h1 class="page-title">Tạo hồ sơ nhân viên mới</h1>
    <p class="page-subtitle">Nhập đầy đủ thông tin cá nhân, liên hệ và phân quyền vai trò công việc cho nhân viên mới.</p>
</div>

<div class="employee-grid-container">
    <!-- Cột Trái: Form tạo mới nhân viên -->
    <div class="card" style="padding: 2rem;">
        <form method="post" class="auth-form" id="create-employee-form">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All" style="margin: 0; padding: 0; list-style: none;"></div>
                </div>
            }

            <!-- Nhóm 1: Thông tin cơ bản -->
            <div class="form-section-title">
                <i class="bi bi-person-vcard"></i> Thông tin cơ bản
            </div>

            <div class="form-row-2col">
                <div class="form-group">
                    <label asp-for="Input.EmployeeCode" class="form-label"></label>
                    <input asp-for="Input.EmployeeCode" class="form-control" placeholder="VD: NV001" autofocus />
                    <span asp-validation-for="Input.EmployeeCode" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.FullName" class="form-label"></label>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row-2col">
                <div class="form-group">
                    <label asp-for="Input.Gender" class="form-label"></label>
                    <select asp-for="Input.Gender" class="form-control">
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                    <span asp-validation-for="Input.Gender" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.DateOfBirth" class="form-label"></label>
                    <input asp-for="Input.DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row-2col">
                <div class="form-group">
                    <label asp-for="Input.Cccd" class="form-label"></label>
                    <input asp-for="Input.Cccd" class="form-control" placeholder="Nhập số CCCD / CMND" />
                    <span asp-validation-for="Input.Cccd" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.AvatarUrl" class="form-label"></label>
                    <input asp-for="Input.AvatarUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="Input.AvatarUrl" class="text-danger"></span>
                </div>
            </div>

            <!-- Nhóm 2: Thông tin liên hệ -->
            <div class="form-section-title" style="margin-top: 1.5rem;">
                <i class="bi bi-telephone-inbound"></i> Thông tin liên hệ
            </div>

            <div class="form-row-2col">
                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" type="email" class="form-control" placeholder="nguyenvana@company.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Phone" class="form-label"></label>
                    <input asp-for="Input.Phone" class="form-control" placeholder="0901234567" />
                    <span asp-validation-for="Input.Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.Address" class="form-label"></label>
                <input asp-for="Input.Address" class="form-control" placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố" />
                <span asp-validation-for="Input.Address" class="text-danger"></span>
            </div>

            <!-- Nhóm 3: Thông tin công việc -->
            <div class="form-section-title" style="margin-top: 1.5rem;">
                <i class="bi bi-briefcase"></i> Thông tin công việc
            </div>

            <div class="form-row-2col">
                <div class="form-group">
                    <label asp-for="Input.HireDate" class="form-label"></label>
                    <input asp-for="Input.HireDate" type="date" class="form-control" />
                    <span asp-validation-for="Input.HireDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.ManagerId" class="form-label"></label>
                    <select asp-for="Input.ManagerId" asp-items="Model.ManagerOptions" class="form-control"></select>
                    <span asp-validation-for="Input.ManagerId" class="text-danger"></span>
                </div>
            </div>

            <!-- Hidden SelectedRole synced from Right Card -->
            <input type="hidden" asp-for="Input.SelectedRole" id="HiddenSelectedRole" />

            <!-- Buttons -->
            <div class="d-flex align-items-center justify-content-end gap-2" style="margin-top: 2rem; border-top: 1px solid #e2e8f0; padding-top: 1.25rem;">
                <a asp-page="/Employees/Index" class="btn btn-outline" style="min-width: 110px;">Hủy</a>
                <button type="submit" class="btn btn-primary" style="min-width: 180px;">
                    <i class="bi bi-person-check-fill me-1"></i> Tạo hồ sơ nhân viên
                </button>
            </div>
        </form>
    </div>

    <!-- Cột Phải: Card Phân quyền Vai trò Hệ thống (Khớp Ảnh Thiết kế) -->
    <div>
        <div class="role-assignment-card">
            <h3 class="role-assignment-title">
                <i class="bi bi-shield-lock me-1" style="color: #2563eb;"></i> Phân quyền
            </h3>

            <div class="form-label" style="font-weight: 700; margin-bottom: 0.75rem;">Vai trò *</div>

            <div class="role-option-list">
                <!-- System Administrator -->
                <div class="role-option-item">
                    <div class="role-option-left">
                        <input type="radio" name="RoleOption" id="role-admin" value="Admin" @(Model.Input.SelectedRole == "Admin" ? "checked" : "") @(!Model.IsAdmin ? "disabled" : "") />
                        <label for="role-admin" class="role-option-label @(!Model.IsAdmin ? "text-muted" : "")">System Administrator</label>
                    </div>
                    <span class="role-badge role-badge-admin">Quản trị hệ thống</span>
                </div>

                <!-- HR Staff -->
                <div class="role-option-item">
                    <div class="role-option-left">
                        <input type="radio" name="RoleOption" id="role-hr" value="HR" @(Model.Input.SelectedRole == "HR" ? "checked" : "") @(!Model.IsAdmin ? "disabled" : "") />
                        <label for="role-hr" class="role-option-label @(!Model.IsAdmin ? "text-muted" : "")">HR Staff</label>
                    </div>
                    <span class="role-badge role-badge-hr">Nhân sự</span>
                </div>

                <!-- Department Manager -->
                <div class="role-option-item">
                    <div class="role-option-left">
                        <input type="radio" name="RoleOption" id="role-manager" value="Manager" @(Model.Input.SelectedRole == "Manager" ? "checked" : "") @(!Model.IsAdmin ? "disabled" : "") />
                        <label for="role-manager" class="role-option-label @(!Model.IsAdmin ? "text-muted" : "")">Department Manager</label>
                    </div>
                    <span class="role-badge role-badge-manager">Trưởng phòng</span>
                </div>

                <!-- Payroll Officer -->
                <div class="role-option-item">
                    <div class="role-option-left">
                        <input type="radio" name="RoleOption" id="role-payroll" value="Payroll" @(Model.Input.SelectedRole == "Payroll" ? "checked" : "") @(!Model.IsAdmin ? "disabled" : "") />
                        <label for="role-payroll" class="role-option-label @(!Model.IsAdmin ? "text-muted" : "")">Payroll Officer</label>
                    </div>
                    <span class="role-badge role-badge-payroll">Kế toán lương</span>
                </div>

                <!-- Employee -->
                <div class="role-option-item" style="background-color: #f8fafc; border-radius: 8px;">
                    <div class="role-option-left">
                        <input type="radio" name="RoleOption" id="role-employee" value="Employee" @(Model.Input.SelectedRole == "Employee" ? "checked" : "") />
                        <label for="role-employee" class="role-option-label" style="color: #2563eb;">Employee</label>
                    </div>
                    <span class="role-badge role-badge-employee">Nhân viên</span>
                </div>
            </div>

            <!-- Ghi chú phân quyền -->
            <div class="role-info-note-box">
                <i class="bi bi-info-circle-fill"></i>
                <div>
                    @if (Model.IsAdmin)
                    {
                        <span><strong>Lưu ý:</strong> Với quyền Admin, bạn có thể tự do phân bổ các vai trò quản trị hệ thống phù hợp cho tài khoản mới.</span>
                    }
                    else
                    {
                        <span><strong>Lưu ý:</strong> Mặc định người dùng được khởi tạo với vai trò <strong>Nhân viên (Employee)</strong>. Việc nâng cấp sang các vai trò quản trị hệ thống khác (HR, Admin) bắt buộc do Admin thực hiện.</span>
                    }
                </div>
            </div>
        </div>

        <!-- Panel Hướng dẫn phụ -->
        <div class="side-panel-card" style="margin-top: 1rem;">
            <div class="panel-header">
                <i class="bi bi-lightbulb"></i>
                <span>Thông tin bổ sung</span>
            </div>
            <p style="font-size: 0.825rem; color: #64748b; margin: 0; line-line: 1.5;">
                Tài khoản sau khi khởi tạo có thể đăng nhập vào hệ thống HRM với thông tin Email và Mật khẩu mặc định được thiết lập bởi hệ thống.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/employee.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleRadios = document.querySelectorAll('input[name="RoleOption"]');
            const hiddenInput = document.getElementById('HiddenSelectedRole');
            roleRadios.forEach(radio => {
                radio.addEventListener('change', function () {
                    if (this.checked && hiddenInput) {
                        hiddenInput.value = this.value;
                    }
                });
            });
        });
    </script>
}
