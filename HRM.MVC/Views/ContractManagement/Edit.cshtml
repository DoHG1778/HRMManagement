@using HRM.Business.DTOs.Contracts
@model UpdateContractRequestDto

@{
    ViewData["Title"] = "Edit Contract";
    var employeeName = ViewBag.EmployeeName as string;
    var contractId = ViewBag.ContractId;
    var createdAt = (DateTime)ViewBag.CreatedAt;
    var daysSinceCreation = (DateTime.Now - createdAt).TotalDays;
    var canEditSalary = daysSinceCreation <= 7;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Contracts</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@contractId">Details</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>

            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Edit Contract: @employeeName</h4>
                </div>
                <div class="card-body">
                    @if (!canEditSalary)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> This contract was created on @createdAt.ToString("dd/MM/yyyy"). 
                            Salary updates are locked after 7 days.
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" name="id" value="@contractId" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ContractType" class="form-label">Contract Type</label>
                                <select asp-for="ContractType" class="form-select">
                                    <option value="Official">Official</option>
                                    <option value="Probation">Probation</option>
                                    <option value="Part-time">Part-time</option>
                                    <option value="Seasonal">Seasonal</option>
                                </select>
                                <span asp-validation-for="ContractType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Salary" class="form-label">Salary (Monthly)</label>
                                <div class="input-group">
                                    <input asp-for="Salary" class="form-control" type="number" step="0.01" readonly="@(!canEditSalary)" />
                                    <span class="input-group-text">VNĐ</span>
                                </div>
                                <span asp-validation-for="Salary" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label">Start Date</label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label">End Date (Optional)</label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label">Reason for Update / Notes</label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Explain why you are updating this contract... (Mandatory)"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Details" asp-route-id="@contractId" class="btn btn-secondary me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-warning px-5">Update Contract</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}