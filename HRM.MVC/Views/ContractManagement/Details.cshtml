@using HRM.Business.DTOs.Contracts
@model ContractResponseDto
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Contract Details";
    var roles = HttpContextAccessor.HttpContext?.Session.GetString("Roles") ?? "";
    var roleList = roles.Split(',').Select(r => r.Trim()).ToList();
    var isAdmin = roleList.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));
    var isHrOrAdmin = roleList.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase) || r.Equals("HR", StringComparison.OrdinalIgnoreCase));
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Contracts</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Details</li>
                </ol>
            </nav>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Contract Details: @Model.EmployeeName</h4>
                    <span class="badge @(Model.Status == "ACTIVE" ? "bg-success" : (Model.Status == "TERMINATED" ? "bg-danger" : "bg-warning text-dark"))">
                        @Model.Status
                    </span>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <h5 class="text-primary border-bottom pb-2">Employee Information</h5>
                            <dl class="row mt-3">
                                <dt class="col-sm-4">Full Name</dt>
                                <dd class="col-sm-8">@Model.EmployeeName</dd>

                                <dt class="col-sm-4">Employee Code</dt>
                                <dd class="col-sm-8">@Model.EmployeeCode</dd>

                                <dt class="col-sm-4">Employee ID</dt>
                                <dd class="col-sm-8">@Model.EmployeeId</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-primary border-bottom pb-2">Contract Information</h5>
                            <dl class="row mt-3">
                                <dt class="col-sm-4">Contract ID</dt>
                                <dd class="col-sm-8">#@Model.ContractId</dd>

                                <dt class="col-sm-4">Contract Type</dt>
                                <dd class="col-sm-8">@Model.ContractType</dd>

                                <dt class="col-sm-4">Salary</dt>
                                <dd class="col-sm-8 text-success font-weight-bold">@Model.Salary.ToString("N0") VNĐ</dd>
                            </dl>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <h5 class="text-primary border-bottom pb-2">Duration</h5>
                            <dl class="row mt-3">
                                <dt class="col-sm-4">Start Date</dt>
                                <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">End Date</dt>
                                <dd class="col-sm-8">@(Model.EndDate?.ToString("dd/MM/yyyy") ?? "Indefinite")</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-primary border-bottom pb-2">Metadata</h5>
                            <dl class="row mt-3">
                                <dt class="col-sm-4">Created At</dt>
                                <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-sm-4">Last Updated</dt>
                                <dd class="col-sm-8">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Never")</dd>
                            </dl>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="text-primary border-bottom pb-2">Notes & Audit Trail</h5>
                        <div class="mt-3">
                            <div class="border p-3 bg-light rounded mt-2 shadow-sm" style="white-space: pre-line; max-height: 200px; overflow-y: auto;">
                                @(string.IsNullOrWhiteSpace(Model.Note) ? "No history available." : Model.Note)
                            </div>
                        </div>
                        <div class="mt-3">
                            <strong>Contract File:</strong>
                            @if (!string.IsNullOrEmpty(Model.ContractFileUrl))
                            {
                                <div class="mt-2">
                                    <a href="@Model.ContractFileUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                        View Attached File
                                    </a>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mt-2 italic">No file attached.</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    
                    @if (Model.Status == "ACTIVE")
                    {
                        @if (isHrOrAdmin)
                        {
                            <a asp-action="Extend" asp-route-id="@Model.ContractId" class="btn btn-info text-white">Extend</a>
                            <a asp-action="Terminate" asp-route-id="@Model.ContractId" class="btn btn-danger">Terminate</a>
                        }
                        
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning">Edit Details</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>