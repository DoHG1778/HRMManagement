@model UpdatePositionRequestDto

@{
    ViewData["Title"] = "Edit Position";
    var positionId = ViewBag.PositionId;
}

<h2>Edit Position</h2>

<form asp-action="Edit" asp-route-id="@positionId" method="post" style="max-width: 520px;">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="PositionName" class="form-label"></label>
        <input asp-for="PositionName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
