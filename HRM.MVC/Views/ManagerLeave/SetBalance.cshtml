@model SetLeaveBalanceRequestDto
@{
    ViewData["Title"] = "Set Leave Balance";
    var leaveTypes = ViewBag.LeaveTypes as List<LeaveTypeResponseDto> ?? new List<LeaveTypeResponseDto>();
}

<h2>Set Leave Balance</h2>

<form asp-action="SetBalance" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Employee ID</label>
        <input asp-for="EmployeeId" type="number" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Leave Type</label>
        <select asp-for="LeaveTypeId" class="form-select">
            @foreach (var lt in leaveTypes)
            {
                <option value="@lt.LeaveTypeId" selected="@(lt.LeaveTypeId == Model.LeaveTypeId)">@lt.LeaveTypeName</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" type="number" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="TotalDays" class="form-label">Total Days</label>
        <input asp-for="TotalDays" type="number" class="form-control" required min="0" />
    </div>

    <div class="mb-3">
        <label asp-for="UsedDays" class="form-label">Used Days</label>
        <input asp-for="UsedDays" type="number" class="form-control" required min="0" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Balances" asp-route-employeeId="@Model.EmployeeId" asp-route-year="@Model.Year" class="btn btn-secondary">Cancel</a>
</form>
