@model List<HRM.Business.DTOs.Attendances.AttendanceAdjustmentResponseDto>
@{
    ViewData["Title"] = "My Attendance Adjustments";
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="bi bi-clock-history text-primary"></i> My Attendance Adjustments</h1>
            <p class="text-muted mb-0 small">Create and track adjustments for your attendance records.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> New Adjustment Request</a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Filter Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="MyRequests" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Month</label>
                    <select name="month" class="form-select form-select-sm">
                        <option value="">All Months</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(ViewBag.CurrentMonth == m)">Month @m</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Year</label>
                    <select name="year" class="form-select form-select-sm">
                        <option value="">All Years</option>
                        @for (int y = DateTime.Now.Year - 3; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" selected="@(ViewBag.CurrentYear == y)">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Status</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        <option value="PENDING" selected="@(ViewBag.CurrentStatus == "PENDING")">PENDING</option>
                        <option value="APPROVED" selected="@(ViewBag.CurrentStatus == "APPROVED")">APPROVED</option>
                        <option value="REJECTED" selected="@(ViewBag.CurrentStatus == "REJECTED")">REJECTED</option>
                        <option value="CANCELLED" selected="@(ViewBag.CurrentStatus == "CANCELLED")">CANCELLED</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-filter"></i> Apply Filters</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Table Card -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Current Check-in/out</th>
                        <th>Requested Check-in/out</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Created At</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i> No adjustment requests found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold">@item.AttendanceDate.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="bi bi-box-arrow-in-right text-success"></i> @(item.CurrentCheckInTime?.ToString("HH:mm") ?? "-")<br />
                                        <i class="bi bi-box-arrow-left text-danger"></i> @(item.CurrentCheckOutTime?.ToString("HH:mm") ?? "-")
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="bi bi-box-arrow-in-right text-success fw-bold"></i> @(item.RequestedCheckInTime?.ToString("HH:mm") ?? "-")<br />
                                        <i class="bi bi-box-arrow-left text-danger fw-bold"></i> @(item.RequestedCheckOutTime?.ToString("HH:mm") ?? "-")
                                    </div>
                                </td>
                                <td>
                                    <div class="text-truncate small" style="max-width: 180px;" title="@item.Reason">@item.Reason</div>
                                </td>
                                <td>
                                    <span class="badge @(item.Status switch {
                                        "PENDING" => "bg-warning text-dark",
                                        "APPROVED" => "bg-success",
                                        "REJECTED" => "bg-danger",
                                        "CANCELLED" => "bg-secondary",
                                        _ => "bg-light text-dark"
                                    })">@item.Status</span>
                                </td>
                                <td class="small text-muted">
                                    @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.AdjustmentId" class="btn btn-xs btn-outline-info btn-sm" title="View Details">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    @if (item.Status == "PENDING")
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.AdjustmentId" class="btn btn-xs btn-outline-primary btn-sm ms-1" title="Edit Request">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form asp-action="Cancel" asp-route-id="@item.AdjustmentId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this pending request?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-outline-danger btn-sm ms-1" title="Cancel Request">
                                                <i class="bi bi-x-circle"></i> Cancel
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
