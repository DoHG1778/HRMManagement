@model EmployeeDetailResponseDto

@{
    ViewData["Title"] = "My Profile";
}

<h2>My Profile</h2>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<table class="table table-bordered">
    <tbody>
        <tr><th>Code</th><td>@Model.EmployeeCode</td></tr>
        <tr><th>Name</th><td>@Model.FullName</td></tr>
        <tr><th>Email</th><td>@Model.Email</td></tr>
        <tr><th>Phone</th><td>@Model.Phone</td></tr>
        <tr><th>Address</th><td>@Model.Address</td></tr>
        <tr><th>Status</th><td>@Model.EmploymentStatus</td></tr>
        <tr><th>Department</th><td>@Model.DepartmentName</td></tr>
        <tr><th>Position</th><td>@Model.PositionName</td></tr>
        <tr><th>Manager</th><td>@Model.ManagerName</td></tr>
    </tbody>
</table>

<a asp-action="EditMyProfile" class="btn btn-primary">Edit My Profile</a>
