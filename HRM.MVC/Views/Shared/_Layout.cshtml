@functions {
    private bool IsLoggedIn()
    {
        return !string.IsNullOrWhiteSpace(Context.Session.GetString("AccessToken"));
    }

    private bool HasAnyRole(params string[] allowedRoles)
    {
        var roleText = Context.Session.GetString("Roles") ?? string.Empty;
        var currentRoles = roleText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return allowedRoles.Any(currentRoles.Contains);
    }

    private string DisabledUnless(bool condition)
    {
        return condition ? string.Empty : "disabled";
    }
}

@{
    var loggedIn = IsLoggedIn();
    var canEmployee = HasAnyRole("Employee");
    var canHrAdmin = HasAnyRole("Admin", "HR", "HR Staff", "System Administrator");
    var canManager = HasAnyRole("Manager", "Department Manager");
    var canPayroll = HasAnyRole("Admin", "Payroll", "Payroll Officer");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRM.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HRM</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Authentication</a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">All Actors</h6></li>
                                <li><a class="dropdown-item" asp-controller="Auth" asp-action="Login">Login</a></li>
                                <li><a class="dropdown-item @DisabledUnless(loggedIn)" asp-controller="Auth" asp-action="ChangePassword">Change Password</a></li>
                                <li><a class="dropdown-item @DisabledUnless(loggedIn)" asp-controller="Auth" asp-action="MyAccount">My Account</a></li>
                                <li><a class="dropdown-item @DisabledUnless(loggedIn)" asp-controller="Auth" asp-action="Logout">Logout</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @DisabledUnless(canEmployee)" href="#" role="button" data-bs-toggle="dropdown">Employee</a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">Self Service</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="EmployeeManagement" asp-action="MyProfile">My Profile</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Leave</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="StaffLeave" asp-action="Index">My Leave Requests</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="StaffLeave" asp-action="Create">Create Leave Request</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Overtime</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="StaffOvertime" asp-action="Index">My OT Requests</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="StaffOvertime" asp-action="Create">Register Overtime</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Attendance Adjustment</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canEmployee)" asp-controller="AttendanceAdjustment" asp-action="MyRequests">My Attendance Adjustments</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @DisabledUnless(canHrAdmin)" href="#" role="button" data-bs-toggle="dropdown">HR / Admin</a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">Employee Management</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="EmployeeManagement" asp-action="Index">Employee List</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="EmployeeManagement" asp-action="Create">Create Employee Profile</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="EmployeeManagement" asp-action="Index">Update Employee Profile / Status</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="EmployeeManagement" asp-action="Index">Assign Employee</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="EmployeeManagement" asp-action="Index">Transfer Employee</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Organization</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="DepartmentManagement" asp-action="Index">Departments</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="PositionManagement" asp-action="Index">Positions</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Leave Administration</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="ManagerLeave" asp-action="LeaveTypes">Leave Types</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canHrAdmin)" asp-controller="ManagerLeave" asp-action="Balances">Leave Balances</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @DisabledUnless(canManager)" href="#" role="button" data-bs-toggle="dropdown">Manager</a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">Employees</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canManager)" asp-controller="EmployeeManagement" asp-action="Index">Department Employees</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canManager)" asp-controller="EmployeeManagement" asp-action="Index">Employee Details</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Approvals</h6></li>
                                <li><a class="dropdown-item @DisabledUnless(canManager)" asp-controller="ManagerLeave" asp-action="Index">Pending Leave Approvals</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canManager)" asp-controller="ManagerOvertime" asp-action="Index">Pending OT Approvals</a></li>
                                <li><a class="dropdown-item @DisabledUnless(canManager)" asp-controller="AttendanceAdjustment" asp-action="Pending">Attendance Adjustment Approvals</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @DisabledUnless(canPayroll)" href="#" role="button" data-bs-toggle="dropdown">Payroll</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item @DisabledUnless(canPayroll)" asp-controller="Payroll" asp-action="Index">Payroll Management</a></li>
                                <li><a class="dropdown-item @DisabledUnless(loggedIn)" asp-controller="Payroll" asp-action="MyPayslip">My Payslip</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @DisabledUnless(loggedIn)" href="#" role="button" data-bs-toggle="dropdown"> Dashboard </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                           asp-controller="Dashboard"
                                           asp-action="Summary">
                                        Summary
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item @DisabledUnless(canEmployee)"
                                           asp-controller="Dashboard"
                                           asp-action="Employee">
                                        Employee Dashboard
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item @DisabledUnless(canManager)"
                                           asp-controller="Dashboard"
                                           asp-action="Manager">
                                        Manager Dashboard
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item @DisabledUnless(canPayroll)"
                                           asp-controller="Dashboard"
                                           asp-action="Payroll">
                                        Payroll Dashboard
                                    </a>
                                </li>

                            </ul>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @DisabledUnless(loggedIn)"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown">
                                    Notifications
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <h6 class="dropdown-header">
                                            Notification Center
                                        </h6>
                                    </li>

                                    <li>
                                        <a class="dropdown-item @DisabledUnless(loggedIn)"
                                               asp-controller="Notification"
                                               asp-action="Index">
                                            My Notifications
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HRM
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
