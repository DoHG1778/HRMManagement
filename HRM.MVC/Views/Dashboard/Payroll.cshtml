@model HRM.Business.DTOs.Dashboards.PayrollDashboardDto

@{
    ViewData["Title"] = "Payroll Dashboard";
}

<style>
.money-value {
    white-space: nowrap !important;
}
</style>

<h2 class="mb-4">Payroll Dashboard</h2>

<div class="row g-3">

    <div class="col-lg mb-3">
        <div class="card border-primary">
            <div class="card-body">
                <h6>Total Payrolls</h6>
                <h3>@Model.TotalPayrolls</h3>
            </div>
        </div>
    </div>

    <div class="col-lg mb-3">
        <div class="card border-secondary">
            <div class="card-body">
                <h6>Draft Payrolls</h6>
                <h3>@Model.DraftPayrolls</h3>
            </div>
        </div>
    </div>

    <div class="col-lg mb-3">
        <div class="card border-warning">
            <div class="card-body">
                <h6>Confirmed Payrolls</h6>
                <h3>@Model.ConfirmedPayrolls</h3>
            </div>
        </div>
    </div>

    <div class="col-lg mb-3">
        <div class="card border-success">
            <div class="card-body">
                <h6>Paid Payrolls</h6>
                <h3>@Model.PaidPayrolls</h3>
            </div>
        </div>
    </div>

</div>

<hr />

<div class="row">

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header bg-white py-3">
                <h5 class="m-0 font-weight-bold text-primary">Salary Summary</h5>
            </div>

            <table class="table mb-0 align-middle">

                <tr>
                    <th>Payroll Month</th>
                    <td>@Model.PayrollMonth</td>
                </tr>

                <tr>
                    <th>Payroll Year</th>
                    <td>@Model.PayrollYear</td>
                </tr>

                <tr>
                    <th>Total Base Salary</th>
                    <td class="money-value fw-bold">@Model.TotalBaseSalary.ToString("N0") ₫</td>
                </tr>

                <tr>
                    <th>Total Gross Salary</th>
                    <td class="money-value text-success">@Model.TotalGrossSalary.ToString("N0") ₫</td>
                </tr>

                <tr>
                    <th>Total Net Salary</th>
                    <td class="money-value text-primary fw-bold">@Model.TotalNetSalary.ToString("N0") ₫</td>
                </tr>

                <tr>
                    <th>Total Overtime</th>
                    <td class="money-value text-success">+@Model.TotalOvertime.ToString("N0") ₫</td>
                </tr>

                <tr>
                    <th>Total Deduction</th>
                    <td class="money-value text-danger">-@Model.TotalDeduction.ToString("N0") ₫</td>
                </tr>

            </table>
        </div>
    </div>

</div>