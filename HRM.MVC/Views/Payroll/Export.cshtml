@using HRM.Business.DTOs.Payrolls
@model PayrollReportDto

@{
    ViewData["Title"] = $"Payroll Report - {Model.PayrollMonth}/{Model.PayrollYear}";
}

<div class="container-fluid py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Payroll Board</a></li>
            <li class="breadcrumb-item active" aria-current="page">Export Summary</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="bi bi-file-earmark-bar-graph"></i> Monthly Payroll Report</h1>
            <p class="text-muted mb-0">Period: <strong>Month @Model.PayrollMonth, Year @Model.PayrollYear</strong> | Released Status Only</p>
        </div>
        <button type="button" class="btn btn-outline-secondary" onclick="window.print();">
            <i class="bi bi-printer"></i> Print Report
        </button>
    </div>

    <!-- Summary Metrics Dashboard -->
    <div class="row g-3 mb-4" id="metricsArea">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body">
                    <span class="small opacity-75">TOTAL EMPLOYEES</span>
                    <h2 class="fw-bold mb-0">@Model.TotalEmployees</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body">
                    <span class="small opacity-75">TOTAL BASE CONTRACTS</span>
                    <h3 class="fw-bold mb-0">@Model.TotalBaseSalary.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                <div class="card-body">
                    <span class="small opacity-75">TOTAL OVERTIME COSTS</span>
                    <h3 class="fw-bold mb-0">@Model.TotalOvertime.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white h-100">
                <div class="card-body">
                    <span class="small opacity-75">NET COMPANY PAYOUT</span>
                    <h3 class="fw-bold mb-0 text-success">@Model.TotalNetSalary.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Details Card -->
    <div class="card shadow-sm border-0" id="reportTableArea">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 font-weight-bold text-dark">Included Payroll Records</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Code</th>
                            <th>Employee Name</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Base Salary</th>
                            <th>Allowance</th>
                            <th>Bonus</th>
                            <th>Overtime</th>
                            <th>Deduction</th>
                            <th>Gross</th>
                            <th>Net Pay</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Payrolls != null && Model.Payrolls.Any())
                        {
                            foreach (var p in Model.Payrolls)
                            {
                                <tr>
                                    <td><strong>@p.EmployeeCode</strong></td>
                                    <td>@p.EmployeeName</td>
                                    <td>@(p.DepartmentName ?? "N/A")</td>
                                    <td>@(p.PositionName ?? "N/A")</td>
                                    <td>@p.BaseSalary.ToString("N0") ₫</td>
                                    <td class="text-success">+@p.TotalAllowance.ToString("N0") ₫</td>
                                    <td class="text-success">+@p.TotalBonus.ToString("N0") ₫</td>
                                    <td class="text-success">+@p.TotalOvertime.ToString("N0") ₫</td>
                                    <td class="text-danger">-@p.TotalDeduction.ToString("N0") ₫</td>
                                    <td>@p.GrossSalary.ToString("N0") ₫</td>
                                    <td class="fw-bold text-dark">@p.NetSalary.ToString("N0") ₫</td>
                                    <td>
                                        <span class="badge @(p.Status switch {
                                            "CONFIRMED" => "bg-warning text-dark",
                                            "PAID" => "bg-success",
                                            _ => "bg-light text-dark"
                                        })">@p.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="12" class="text-center py-4 text-muted">No confirmed or paid payroll sheets found for this period to display.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style media="print">
        body * {
            visibility: hidden;
        }
        #metricsArea, #metricsArea *, #reportTableArea, #reportTableArea * {
            visibility: visible;
        }
        #metricsArea {
            position: absolute;
            left: 0;
            top: 20px;
            width: 100%;
        }
        #reportTableArea {
            position: absolute;
            left: 0;
            top: 220px;
            width: 100%;
        }
    </style>
}
