@using HRM.Business.DTOs.Payrolls
@model PayrollResponseDto

@{
    ViewData["Title"] = $"Payroll Details - {Model.EmployeeName}";
    bool isEditable = Model.Status == "DRAFT";
    int index = 0;
}
<style>
.money-value {
    white-space: nowrap !important;
}
</style>

<div class="container py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Payroll Board</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details: @Model.EmployeeName</li>
        </ol>
    </nav>

    <!-- Title and Employee card info -->
    <div class="card shadow-sm border-0 mb-4 bg-primary text-white">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                @if (Model.Status == "DRAFT")
                {
                    if (Model.UpdatedAt == null)
                    {
                        <span class="badge bg-light text-secondary mb-2">DRAFT - Not Calculated</span>
                    }
                    else
                    {
                        <span class="badge bg-light text-info mb-2">DRAFT - Calculated</span>
                    }
                }
                else
                {
                    <span class="badge bg-light text-primary mb-2">@Model.Status</span>
                }
                <h2 class="mb-1">@Model.EmployeeName</h2>
                <p class="mb-0 opacity-75">Code: <strong>@Model.EmployeeCode</strong> | Department: @(Model.DepartmentName ?? "N/A") | Position: @(Model.PositionName ?? "N/A")</p>
            </div>
            <div class="text-end">
                <span class="d-block small opacity-75">Payroll Month</span>
                <h3>@Model.PayrollMonth/@Model.PayrollYear</h3>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Totals summary column -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 font-weight-bold text-dark">Salary Summary</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <span class="text-muted">Base Contract Salary:</span>
                        <span class="fw-bold">@Model.BaseSalary.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 text-success">
                        <span>Total Allowance:</span>
                        <span>+@Model.TotalAllowance.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 text-success">
                        <span>Total Bonus:</span>
                        <span>+@Model.TotalBonus.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 text-success">
                        <span>Total Overtime Pay:</span>
                        <span>+@Model.TotalOvertime.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 text-danger">
                        <span>Total Deduction:</span>
                        <span>-@Model.TotalDeduction.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 bg-light p-2">
                        <span class="fw-bold text-dark">Gross Salary:</span>
                        <span class="fw-bold">@Model.GrossSalary.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-2 mb-3 bg-primary text-white rounded">
                        <span class="fw-bold">Net Take-Home Salary:</span>
                        <span class="fs-5 fw-bold">@Model.NetSalary.ToString("N0") ₫</span>
                    </div>
                    
                    <div class="text-muted small">
                        <div>Generated by User ID: @(Model.GeneratedByUserId?.ToString() ?? "N/A") (@(Model.GeneratedByUsername ?? "N/A"))</div>
                        @if (Model.ConfirmedByUserId.HasValue)
                        {
                            <div>Confirmed by User ID: @Model.ConfirmedByUserId.Value (@Model.ConfirmedByUsername)</div>
                            <div>Confirmed At: @(Model.ConfirmedAt?.ToString("g") ?? "N/A")</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Detail item items column / Interactive Editor -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 font-weight-bold text-primary">Payroll Breakdown                    @if (isEditable)
                    {
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="addRow()">
                            <i class="bi bi-plus-lg"></i> Add Custom Row
                        </button>
                    }
                </div>
                <div class="card-body">
                    <form asp-controller="Payroll" asp-action="UpdateDetails" asp-route-id="@Model.PayrollId" method="post" id="detailsForm">
                        <div class="table-responsive">
                            <table class="table table-bordered mb-3" id="detailsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 25%">Item Type</th>
                                        <th style="width: 40%">Description</th>
                                        <th style="width: 25%">Amount (₫)</th>
                                        @if (isEditable)
                                        {
                                            <th style="width: 10%" class="text-center">Action</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.PayrollDetails != null && Model.PayrollDetails.Any())
                                    {
                                        foreach (var detail in Model.PayrollDetails)
                                        {
                                            bool isAutoOt = detail.SourceType == "OVERTIME";
                                            bool canEditRow = isEditable && !isAutoOt;
                                            <tr>
                                                <td>
                                                    @if (canEditRow)
                                                    {
                                                        <select name="Items[@index].ItemType" class="form-select form-select-sm">
                                                            <option value="ALLOWANCE" selected="@(detail.ItemType == "ALLOWANCE")">ALLOWANCE</option>
                                                            <option value="BONUS" selected="@(detail.ItemType == "BONUS")">BONUS</option>
                                                            <option value="DEDUCTION" selected="@(detail.ItemType == "DEDUCTION")">DEDUCTION</option>
                                                            <option value="OVERTIME" selected="@(detail.ItemType == "OVERTIME")">OVERTIME</option>
                                                            <option value="OTHER" selected="@(detail.ItemType == "OTHER")">OTHER</option>
                                                        </select>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@detail.ItemType</span>
                                                        <input type="hidden" name="Items[@index].ItemType" value="@detail.ItemType" />
                                                    }
                                                </td>
                                                <td>
                                                    @if (canEditRow)
                                                    {
                                                        <input type="text" name="Items[@index].Description" value="@detail.Description" class="form-control form-control-sm" placeholder="e.g. Fuel allowance, late fine" required />
                                                    }
                                                    else
                                                    {
                                                        <span>@detail.Description</span>
                                                        <input type="hidden" name="Items[@index].Description" value="@detail.Description" />
                                                    }
                                                </td>
                                                <td>
                                                    @if (canEditRow)
                                                    {
                                                        <input type="number" name="Items[@index].Amount" value="@((int)detail.Amount)" class="form-control form-control-sm text-end" min="0" step="1000" required />
                                                    }
                                                    else
                                                    {
                                                        <span class="d-block text-end">@detail.Amount.ToString("N0") ₫</span>
                                                        <input type="hidden" name="Items[@index].Amount" value="@detail.Amount" />
                                                    }
                                                    <input type="hidden" name="Items[@index].SourceType" value="@detail.SourceType" />
                                                    <input type="hidden" name="Items[@index].SourceId" value="@detail.SourceId" />
                                                </td>
                                                @if (isEditable)
                                                {
                                                    <td class="text-center">
                                                        @if (!isAutoOt)
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteRow(this)">
                                                                Remove
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small">Auto (OT)</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                            index++;
                                        }
                                    }
                                    else if (!isEditable)
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center py-3 text-muted">No details found for this payroll.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (isEditable)
                        {
                            <div class="d-flex justify-content-end gap-2 mt-3">
                                <a asp-action="Index" class="btn btn-secondary btn-sm">Discard</a>
                                <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-save"></i> Save Changes</button>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning small py-2 mb-0" role="alert">
                                <i class="bi bi-info-circle"></i> This payroll has been locked (@Model.Status) and can no longer be modified.
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let rowCount = @index;

        function addRow() {
            const tableBody = document.querySelector('#detailsTable tbody');
            
            // If table has empty placeholder row, remove it
            const emptyRow = tableBody.querySelector('.text-muted');
            if (emptyRow) {
                tableBody.innerHTML = '';
            }

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>
                    <select name="Items[\${rowCount}].ItemType" class="form-select form-select-sm">
                        <option value="ALLOWANCE">ALLOWANCE</option>
                        <option value="BONUS">BONUS</option>
                        <option value="DEDUCTION">DEDUCTION</option>
                        <option value="OVERTIME">OVERTIME</option>
                        <option value="OTHER">OTHER</option>
                    </select>
                </td>
                <td>
                    <input type="text" name="Items[\${rowCount}].Description" class="form-control form-control-sm" placeholder="Description of addition/deduction" required />
                </td>
                <td>
                    <input type="number" name="Items[\${rowCount}].Amount" value="0" class="form-control form-control-sm text-end" min="0" step="1000" required />
                    <input type="hidden" name="Items[\${rowCount}].SourceType" value="MANUAL" />
                    <input type="hidden" name="Items[\${rowCount}].SourceId" value="" />
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteRow(this)">Remove</button>
                </td>
            `;
            tableBody.appendChild(tr);
            rowCount++;
            reindexInputs();
        }

        function deleteRow(btn) {
            const row = btn.closest('tr');
            row.remove();
            reindexInputs();
        }

        function reindexInputs() {
            const rows = document.querySelectorAll('#detailsTable tbody tr');
            rowCount = 0;
            rows.forEach((row, i) => {
                const select = row.querySelector('select');
                if (select) select.setAttribute('name', `Items[${i}].ItemType`);
                
                const inputs = row.querySelectorAll('input');
                inputs.forEach(input => {
                    const name = input.getAttribute('name');
                    if (name.includes('.Description')) input.setAttribute('name', `Items[${i}].Description`);
                    if (name.includes('.Amount')) input.setAttribute('name', `Items[${i}].Amount`);
                    if (name.includes('.SourceType')) input.setAttribute('name', `Items[${i}].SourceType`);
                    if (name.includes('.SourceId')) input.setAttribute('name', `Items[${i}].SourceId`);
                });
                rowCount++;
            });
        }
    </script>
}
