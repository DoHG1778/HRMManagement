@model UpdateLeaveRequestDto
@{
    ViewData["Title"] = "Edit Leave Request";
    var leaveTypes = ViewBag.LeaveTypes as List<LeaveTypeResponseDto> ?? new List<LeaveTypeResponseDto>();
}

<h2>Edit Leave Request</h2>

<form asp-action="Edit" method="post" onsubmit="return validateAndCalculate()">
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@error.ErrorMessage</p>
            }
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Leave Type</label>
        <select asp-for="LeaveTypeId" class="form-select" required>
            <option value="">-- Select Leave Type --</option>
            @foreach (var lt in leaveTypes)
            {
                <option value="@lt.LeaveTypeId" data-max="@lt.MaxDaysPerYear">
                    @lt.LeaveTypeName (max @lt.MaxDaysPerYear days/year)
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Total Days</label>
        <input name="totalDays" id="TotalDays" type="number" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Reason</label>
        <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <script>
        function validateAndCalculate() {
            var start = document.getElementById('StartDate');
            var end = document.getElementById('EndDate');
            var totalDays = document.getElementById('TotalDays');
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            var startDate = new Date(start.value);
            var endDate = new Date(end.value);

            if (start.value && startDate < today) {
                alert('Start date cannot be in the past.');
                return false;
            }
            if (end.value && endDate < today) {
                alert('End date cannot be in the past.');
                return false;
            }
            if (start.value && end.value && endDate < startDate) {
                alert('End date must be >= Start date.');
                return false;
            }
            if (start.value && end.value) {
                var diff = Math.floor((endDate - startDate) / (1000 * 60 * 60 * 24)) + 1;
                totalDays.value = diff;
            }
            return true;
        }
    </script>
}
