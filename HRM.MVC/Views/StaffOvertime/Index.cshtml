@model List<OvertimeRequestResponseDto>
@{
    ViewData["Title"] = "My Overtime Requests";
}

<h2>My Overtime Requests</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Register Overtime</a>
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            <option value="PENDING" selected="@(ViewBag.CurrentStatus == "PENDING")">Pending</option>
            <option value="APPROVED" selected="@(ViewBag.CurrentStatus == "APPROVED")">Approved</option>
            <option value="REJECTED" selected="@(ViewBag.CurrentStatus == "REJECTED")">Rejected</option>
            <option value="CANCELLED" selected="@(ViewBag.CurrentStatus == "CANCELLED")">Cancelled</option>
        </select>
    </div>
    <div class="col-auto">
        <input type="number" name="month" class="form-control" placeholder="Month" value="@ViewBag.CurrentMonth" style="width:90px" />
    </div>
    <div class="col-auto">
        <input type="number" name="year" class="form-control" placeholder="Year" value="@ViewBag.CurrentYear" style="width:90px" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Date</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Hours</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Otid</td>
                <td>@item.Otdate.ToString("dd/MM/yyyy")</td>
                <td>@item.StartTime.ToString("HH:mm")</td>
                <td>@item.EndTime.ToString("HH:mm")</td>
                <td>@item.TotalHours</td>
                <td>@item.Reason</td>
                <td>
                    <span class="badge bg-@(item.Status == "PENDING" ? "warning" : item.Status == "APPROVED" ? "success" : item.Status == "REJECTED" ? "danger" : "secondary")">
                        @item.Status
                    </span>
                </td>
                <td>
                    @if (item.Status == "PENDING")
                    {
                        <a asp-action="Edit" asp-route-id="@item.Otid" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="Cancel" method="post" style="display:inline" onsubmit="return confirm('Cancel this request?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Otid" />
                            <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="8" class="text-center">No overtime requests found.</td></tr>
        }
    </tbody>
</table>
