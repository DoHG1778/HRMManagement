@using HRM.Business.DTOs.Users
@using HRM.Business.DTOs.Employees
@model UpdateUserRequestDto

@{
    ViewData["Title"] = "Edit User Account";
    var roles = ViewBag.Roles as List<RoleResponseDto> ?? new List<RoleResponseDto>();
    var username = ViewBag.Username as string;
    var userId = ViewBag.UserId;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Edit User Account: @username</h4>
                    <span class="badge @(Model.IsActive == true ? "bg-success" : "bg-danger")">
                        @(Model.IsActive == true ? "Active" : "Locked")
                    </span>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@userId" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" name="id" value="@userId" />

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label font-weight-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Account Status</label>
                            <div class="form-check form-switch">
                                @* Sửa lỗi: Sử dụng checkbox thông thường thay cho asp-for vì IsActive là kiểu nullable bool *@
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="statusSwitch" @(Model.IsActive == true ? "checked" : "")>
                                <input type="hidden" name="IsActive" value="false" />
                                <label class="form-check-label" for="statusSwitch">
                                    Enabled (User can login)
                                </label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label font-weight-bold">Assign Roles (Phân quyền)</label>
                            <div class="border rounded p-3 bg-light">
                                <div class="row">
                                    @foreach (var role in roles)
                                    {
                                        <div class="col-md-4 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="RoleIds" 
                                                       value="@role.RoleId" id="role_@role.RoleId"
                                                       @(Model.RoleIds != null && Model.RoleIds.Contains(role.RoleId) ? "checked" : "")>
                                                <label class="form-check-label" for="role_@role.RoleId">
                                                    @role.RoleName
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <small class="text-muted">At least one role is required for login.</small>
                        </div>

                        <hr />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle"></i> 
                <strong>Note:</strong> Locking an account or removing the Admin role from the last active administrator is restricted by system policy.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}