@using HRM.Business.Common
@using HRM.Business.DTOs.Attendances
@model PagedResult<AttendanceResponseDto>

@{
    ViewData["Title"] = "Attendance";
    var todayRecord = ViewBag.TodayRecord as AttendanceResponseDto;
    var filter = ViewBag.Filter as AttendanceFilterDto ?? new AttendanceFilterDto();

    bool canCheckIn = todayRecord == null;
    bool canCheckOut = todayRecord != null && !todayRecord.CheckOutTime.HasValue;
    bool alreadyCheckedOut = todayRecord != null && todayRecord.CheckOutTime.HasValue;
}

<div class="container-fluid px-4 py-3" style="background-color: #f8f9fa; min-height: 100vh;">
    <!-- Title Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Attendance</h2>
            <div class="d-flex align-items-center gap-2 text-muted">
                <span>@DateTime.Now.ToString("dddd, dd/MM/yyyy")</span>
                <span class="badge bg-success-subtle text-success px-2 py-1">Working Day</span>
            </div>
        </div>
        <div class="text-end">
            <h3 id="live-clock" class="fw-bold mb-0" style="color: #0d6efd;">00:00:00</h3>
        </div>
    </div>

    <!-- Attendance Action Card -->
    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <!-- Status & Info -->
                <div class="col-lg-3 border-end">
                    <p class="text-muted small mb-2 text-uppercase fw-bold">Attendance Status</p>
                    @if (alreadyCheckedOut)
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="p-1 bg-secondary rounded-circle"></span>
                            <span class="fw-bold text-secondary">Finished</span>
                        </div>
                        <p class="small text-muted mb-0">You have completed your work for today.</p>
                    }
                    else if (todayRecord != null)
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="p-1 bg-success rounded-circle animate-pulse"></span>
                            <span class="fw-bold text-success">Working</span>
                        </div>
                        <p class="small text-muted mb-0">You checked in at <strong>@todayRecord.CheckInTime?.ToString("HH:mm")</strong></p>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="p-1 bg-warning rounded-circle"></span>
                            <span class="fw-bold text-warning">Not Started</span>
                        </div>
                        <p class="small text-muted mb-0">Please check in to start your work day.</p>
                    }
                </div>

                <!-- Check-in Time -->
                <div class="col-lg-2 text-center border-end">
                    <p class="text-muted small mb-1">Check In</p>
                    <h4 class="fw-bold mb-1">@(todayRecord?.CheckInTime?.ToString("HH:mm") ?? "--:--")</h4>
                    @if (todayRecord != null)
                    {
                        <span class="text-success small"><i class="bi bi-check-circle-fill"></i> @(todayRecord.Status == "LATE" ? "Late" : "On Time")</span>
                    }
                </div>

                <!-- Check-out Time -->
                <div class="col-lg-2 text-center">
                    <p class="text-muted small mb-1">Check Out</p>
                    <h4 class="fw-bold mb-1">@(todayRecord?.CheckOutTime?.ToString("HH:mm") ?? "--:--")</h4>
                    @if (alreadyCheckedOut)
                    {
                        <span class="text-muted small">Recorded</span>
                    }
                    else
                    {
                        <span class="text-muted small">Not yet</span>
                    }
                </div>

                <!-- Action Buttons -->
                <div class="col-lg-5 ps-4">
                    <div class="row g-2">
                        <div class="col-6">
                            <form asp-action="CheckIn" method="post">
                                <button type="submit" class="btn btn-success w-100 py-3 rounded-3 fw-bold d-flex flex-column align-items-center gap-1 @(canCheckIn ? "" : "disabled")" @(canCheckIn ? "" : "disabled")>
                                    <i class="bi bi-box-arrow-in-right fs-4"></i>
                                    <span>Check In</span>
                                </button>
                            </form>
                        </div>
                        <div class="col-6">
                            <form asp-action="CheckOut" method="post">
                                <button type="submit" class="btn btn-danger w-100 py-3 rounded-3 fw-bold d-flex flex-column align-items-center gap-1 @(canCheckOut ? "" : "disabled")" @(canCheckOut ? "" : "disabled")>
                                    <i class="bi bi-box-arrow-left fs-4"></i>
                                    <span>Check Out</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- History & Table Section -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white py-3 border-0">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0 text-dark">Attendance History</h5>
                <form asp-action="Index" method="get" class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center gap-1">
                        <small class="text-muted fw-bold">Start:</small>
                        <input type="date" name="FromDate" class="form-control form-control-sm border-light" value="@filter.FromDate?.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <small class="text-muted fw-bold">End:</small>
                        <input type="date" name="ToDate" class="form-control form-control-sm border-light" value="@filter.ToDate?.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <small class="text-muted fw-bold">Status:</small>
                        <select name="Status" class="form-select form-select-sm border-light" style="width: 110px;">
                            <option value="">All</option>
                            <option value="PRESENT" selected="@(filter.Status == "PRESENT")">On Time</option>
                            <option value="LATE" selected="@(filter.Status == "LATE")">Late</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm px-3">Filter</button>
                </form>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small">
                            <th class="ps-4">Date</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Total Hours</th>
                            <th class="pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">@item.AttendanceDate.ToString("dddd, dd/MM/yyyy")</td>
                                    <td class="text-success fw-bold">@(item.CheckInTime?.ToString("HH:mm") ?? "--:--")</td>
                                    <td class="text-danger fw-bold">@(item.CheckOutTime?.ToString("HH:mm") ?? "--:--")</td>
                                    <td>@item.WorkingHours h</td>
                                    <td class="pe-4">
                                        @if (item.Status == "PRESENT")
                                        {
                                            <span class="badge bg-success-subtle text-success px-2 py-1">On Time</span>
                                        }
                                        else if (item.Status == "LATE")
                                        {
                                            <span class="badge bg-warning-subtle text-warning px-2 py-1">Late</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark px-2 py-1">@item.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">No attendance history found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-3">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link shadow-none" asp-action="Index" asp-route-pageNumber="@i" asp-route-fromDate="@filter.FromDate" asp-route-toDate="@filter.ToDate">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>

    <!-- Rule Summary -->
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="text-info fw-bold text-uppercase small mb-2">Work Rules</h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="d-flex justify-content-between mb-1">
                            <span>Standard Shift:</span>
                            <span class="fw-bold">08:00 - 17:00</span>
                        </li>
                        <li class="d-flex justify-content-between">
                            <span>Late Grace Period:</span>
                            <span class="fw-bold">Before 8:30 AM</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% { box-shadow: 0 0 0 0px rgba(40, 167, 69, 0.4); }
        100% { box-shadow: 0 0 0 10px rgba(40, 167, 69, 0); }
    }
    
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .btn-success { background-color: #28a745; border: none; }
    .btn-danger { background-color: #dc3545; border: none; }
    .btn-success:hover { background-color: #218838; }
    .btn-danger:hover { background-color: #c82333; }
</style>

@section Scripts {
    <script>
        function updateTime() {
            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ":" +
                          now.getMinutes().toString().padStart(2, '0') + ":" +
                          now.getSeconds().toString().padStart(2, '0');
            document.getElementById('live-clock').innerText = timeStr;
        }
        setInterval(updateTime, 1000);
        updateTime();
    </script>
}
